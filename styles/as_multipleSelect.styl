@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.msc
    &-article
        background-color transparent
    &-remaining
        padding .5rem
        background-color $lightgrey
        border-radius $radius
        text-align center
    &-renderer
        background-color $white
        border-radius $radius 0 0 $radius
        border 1px solid $color-primary-grey
        border-right none
        padding 1rem
    &-checkbox
        border 3px solid $mediumgrey
        &:after
            content ''
            display block
            height 20px
            width 12px
            background none
            position absolute
            left 5px
            top 17px
            border-right 5px solid $white
            border-top 5px solid $white
            transform scaleX(-1) rotate(135deg)
            transform-origin left top
    &-question
        background-color $white
        border 1px solid $color-primary-grey
        border-radius 0 $radius $radius 0
        border-left none
        padding 1rem
        &__label
            font-weight bold
            color $darkgrey
            margin-right 5px
    &-accordion
        &__content
            background-color $lightgrey
    &-label
        &.optionSelected
            .msc
                &-checkbox
                    border 1px solid $color-primary-pink
                    background-color $color-primary-pink
                    &:after
                        border-color $white
                        vendor(animation, check .5s ease)
                &-renderer
                    background-color $white
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 600px)
    .msc
        &-article
            font-size .8rem
        &-renderer
            padding .5rem
        &-question
            padding .5rem
            &__description
                padding-right 40px