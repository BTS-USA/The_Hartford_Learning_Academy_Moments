@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.iwc
    &-container
        padding 2rem
    &-instructions
        text-align left
    &-article
        margin 0 auto
    &-figure
        &__image
            border-radius $radius
            overflow hidden
        &__caption
            color $white
    /*------------------------------------image carousel------------------------------------------------------------------*/
    &-slider
        max-width 100%
        padding 0 1rem
        .slidesjs
            &-container
                border-radius $radius
                height 400px !important
                background-color $white
            &-control
                height 100% !important
                .iwc-article
                    .iwc-figure
                        width 70%
                        margin auto
                        padding 1rem 0
                        &__image
                            border-radius 0
                            box-shadow none
                        &__caption
                            display none
            &-navigation
                display block
                bottom auto
                vendor(transform, translateY(-40px))
                top 50%
                z-index 10
                padding 0
                font-size 0
                height 30px
                width 30px
                line-height 30px
                border-radius 50%
                background-color $color-primary
                vendor(transition, all .5s ease)
                &:hover
                    background-color $color-primary-Medium
                &:before
                    font-family 'fa-solid-900'
                    font-size 1.2rem
                    text-align center
            &-previous:before
                content '\f104'
            &-next:before
                content '\f105'
            &-pagination
                display inline-block
                background-color $darkgrey
                border-radius 2rem
                padding .5rem
                margin-top -2rem
                position relative
                z-index 11
                &-item
                    padding 0
                    a
                        display inline-block
                        background-color transparent
                        padding 0
                        height 20px
                        width 20px
                        line-height 20px
                        border-radius 50%
                        text-align center
                        font-size 14px
                        &.active
                            background-color $color-primary-pink !important
    /*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 768px)
    .iwc-slider
        .slidesjs-container
            height 300px !important
@media screen and (max-width 600px)
    .iwc-slider
        .slidesjs-container
            height 200px !important