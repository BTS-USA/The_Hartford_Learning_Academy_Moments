@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.ic
    &-h3
        color $color-primary-pink
        font-weight bold
    &-paragraph, &-list
        color $mediumgrey
        table
            tr
                th
                    background-color $color-primary-blue
                    padding .5rem
                    color $white
                    font-weight normal
                    border 1px solid $color-primary-blue
                td
                    width 33.33%
                    padding 1rem
                    border 1px solid $color-primary-blue
                &:nth-child(odd)
                    td
                        background-color $color-primary-grey
                        color $black
                &:nth-child(even)
                    td
                        background-color $lightgrey
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 600px)
    .ic-paragraph
        overflow-x auto
        table tr td
            padding .5rem