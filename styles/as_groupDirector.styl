@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.groupDirectorContentWrapper
    .groupDirector-container
        padding 0
        max-width none
    .qncArticle
        display none
    .groupDirectorVoteCountContainer
        width 16rem
        margin 1rem auto -10px
        border-radius 2rem
        display flex
        justify-content center
        align-items center
        position relative
        z-index 1
        background-color #EAE5DF
        .groupdirectorvotecountlabel,
        .groupDirectorVoteCount
            width auto
    .JumpMenuWrapper
        .JumpMenuContainer
            .jumpMenuItem
                position relative
                background-color #eae5df
                color $color-primary-pink
                border-radius $radius
                border 1px solid $color-primary-grey
                &:hover
                    background $color-primary-pink
                    border-color $color-primary-pink
                    color $white
                &.currentActionAction
                    background $color-primary-blue
                    color $white !important
                    border-left none
                    &:hover
                        background $color-primary-pink
                        border-color $color-primary-pink
                &.currentActionEmbed, &.currentActionCommand
                    background-color $color-secondary-blue
                    color $white !important
                    border-left none
                    &:hover
                        background-color $color-primary-pink
                        border-color $color-primary-pink
    .embeddingWrapper
        position relative
        clear none
        float left
        .wizlet.wizletAggregator
            position absolute
            top 9px
            right 9px
            width 35px
            height 54px
            background-color $color-secondary-blue
            padding 15px 10px
            &:after
                content '\f00c'
                font-family 'fa-solid-900'
                color $white
            .textContent
                display none