@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.pc
    &-content
        overflow hidden
    &-listleft
        width 50px
    &-listright
        width calc(100% - 50px)
    &-rightpanel
        margin-bottom 2px
        background-color $white
        padding-right 1rem
        cursor move
        border-radius $radius
        border 1px solid $color-primary-grey
        color $mediumgrey
        flex()
        justify-content space-between
        align-items center
        &:after
            content '\f338'
            font-family 'fa-solid-900'
        .ranking-question__label
            float left
            margin-right 5px
    &-rowitem
        margin-bottom 2px
        &.ui-sortable-helper
            color $darkgrey
            box-shadow $shadow
    &-order
        &listleftpanel
            background-color transparent
            margin-bottom 2px
            width 50px
        &index
            height 40px
            width 40px
            border-radius 50%
            border 4px solid $color-primary-pink
            color $color-primary-pink
            display block
            font-size 1.1rem
            font-weight bold
            line-height 32px
    &-votes
        margin 0
        padding 1rem
    &-draggablecontainer
        display none
    &-button
        float none !important
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 600px)
    .pc
        &-listleft, &-orderlistleftpanel
            width 40px
        &-orderindex
            height 30px
            width 30px
            line-height 26px
            font-size 1rem
            border-width 2px
        &-listright
            width calc(100% - 40px)
        &-votes
            font-size .8rem
            padding .5rem