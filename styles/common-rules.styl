@font-face
  font-family 'fa-regular-400'
  src url("../fonts/fa-regular-400.eot")
  src url("../fonts/fa-regular-400.eot?#iefix") format("embedded-opentype"), url("../fonts/fa-regular-400.woff2") format("woff2"), url("../fonts/fa-regular-400.woff") format("woff"), url("../fonts/fa-regular-400.ttf") format("truetype"), url("../fonts/fa-regular-400.svg#fontawesome") format("svg")
@font-face
  font-family 'fa-solid-900'
  src url("../fonts/fa-solid-900.eot")
  src url("../fonts/fa-solid-900.eot?#iefix") format("embedded-opentype"), url("../fonts/fa-solid-900.woff2") format("woff2"), url("../fonts/fa-solid-900.woff") format("woff"), url("../fonts/fa-solid-900.ttf") format("truetype"), url("../fonts/fa-solid-900.svg#fontawesome") format("svg")
/*------------------------------------------------------------------------------------------------------------------------------------------*/
/*Neutrals*/
$white = #ffffff
$mediumgrey = #868789
$darkgrey = #1e1e1e
$black = #000000
/*Neutrals-additional*/
$lightgrey = #efefef
$grey = #dfe1df
/*Primary color and shades*/
$color-primary-blue = #28324B
$color-primary-pink = #75013F
$color-primary-grey = #CFD1D0
/*Secondary color and shades*/
$color-secondary-skyblue = #0AB9F0
$color-secondary-blue = #75013F
$color-secondary-yellow = #E8CD41
/*Tertiary colors*/
$turquoise = #16B2AB
$steelblue = #727FAE
$green = #72BF44
$red = #F00A3C
$yellow =#DFDF00
/*Gradients*/
$gradient-pink = linear-gradient(to right bottom, $color-primary-pink 0%, $red 100%)
$gradient-skyblue = linear-gradient(to right bottom, $color-secondary-skyblue 0%, $color-secondary-blue 100%)
$gradient-green = linear-gradient(to right bottom, $green 0%, $turquoise 100%)
$gradient-blue = linear-gradient(to right bottom, $color-secondary-blue 0%, $color-primary-blue 100%)
$gradient-grey = linear-gradient(to right bottom, $color-primary-grey 0%, $mediumgrey 100%)

$gradient-header = linear-gradient(to right, $color-secondary-blue 0%, $color-primary-blue 90%, $color-primary-pink 120%)
/*Frequently used*/
$overlay = rgba(0, 0, 0, 0.7)
$shadow = 1rem 1rem 3rem -0.5rem rgba(0, 0, 0, 0.4)
$radius = 5px
/*------------------------------------------------------------------------------------------------------------------------------------------*/
body, p, li, input, button
    font-weight normal
    line-height normal
h1, h2, h3
    font-weight normal
    line-height normal
    margin 0
ul, ol
    margin 0
    padding .5rem 0
li
    margin-left 20px
    padding 5px 0
/*------------------------------------------------------------------------------------------------------------------------------------------*/
input[type=button]
    -webkit-appearance none !important
.designedButton, .dBGraphics
    visibility hidden
    display none !important
#filterSelector
    display none
/*------------------------------------------------------------------------------------------------------------------------------------------*/
*
    -webkit-user-select none
    -moz-user-select none
    -ms-user-select none
    user-select none
textarea, input, .cl-textarea
    -webkit-user-select initial
    -moz-user-select initial
    -ms-user-select initial
    user-select initial
    border 1px solid $color-primary-grey
    border-radius $radius
    box-shadow inset 5px 5px 10px rgba(0,0,0,0.2)
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.shield
    position absolute
    top 0
    left 0
    height 100%
    width 100%
    background-color $overlay
    &.hidden
        display none
.readonly
    pointer-events none
    .cl-foote
        display none
.disabled
    pointer-events none
/*------------------------------------------------------------------------------------------------------------------------------------------*/
blockquote
    padding 1.5rem
    background-color $lightgrey
    border-radius $radius
    position relative
    margin-top 2.5rem
    &:before, &:after
        content '\f10d'
        font-family 'fa-solid-900'
        position absolute
        color $color-primary
    &:before
        font-size 3rem
        top -30px
        left 10px
    &:after
        content '\f10e'
        font-size 2rem
        bottom -18px
        right 10px
/*------------------------------------------------------------------------------------------------------------------------------------------*/
vendor(prop, args)
  -webkit-{prop} args
  -moz-{prop} args
  -ms-{prop} args
  {prop} args

flex()
    display flex
    display -webkit-box
    display -moz-box
    display -ms-flexbox
    display -webkit-flex
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@keyframes check
    0%
        height 0
        width 0
    25%
        height 0
        width 12px
    50%
        height 20px
        width 12px
@keyframes rotate
    0%
        transform scale(0)
    100%
        transform scale(1)
@keyframes wobble
    33%
        transform rotate(20deg)
    66%
        transform rotate(-20deg)
@keyframes toggler-left
    0%
      left 50%
    100%
      left 0
@keyframes toggler-right
    0%
      right 50%
    100%
      right 0