// import variables and mixins
@import "../../../../content/WizletResources/themes/default/shared/cl.styl"
 
// Individual Results Component Styles
.infoAreaComponent
    width 100%
    max-width 1024px
    min-width 1024px
    height 723px
    max-height 723px
    min-height 723px
    margin 0 auto
    .ia-container-holder
        width 100%
        height 100%
        .ia-container
            // styles for block
            width 100%
            height 100%
            margin 0
            max-width 100%
            &>.cl-row
                padding 0
            .ia-content
                background-size 1225px 723px
                width 100%
                height 723px
                max-height 723px
                position relative
                margin 0 auto
                [data-info-area-element]
                    position absolute
                    cursor pointer
                    &:hover
                        background rgba(255,255,255,0.2);
                    &[class*=iaElement-]
                        width 146px
                        height 46px
                        border-radius 26px
                    &.iaElement-0
                        top 40px
                        left 22px
                    &.iaElement-1
                        bottom 245px
                        left 168px
                        //background rgba(0,255,0,0.3)
                        
                    &.iaElement-2
                        top 288px
                        right 127px
                        //background rgba(0,0,255,0.3)
                    &.iaElement-3
                        bottom 195px
                        right 229px
                    // &.iaElement-4
                    //     left 25px
                    //     top 137px
                    //     width 220px
                    //     height 102px
                    // &.iaElement-5
                    //     top 10px
                    //     left 337px
                    //     width 113px
                    //     height 60px
                    // &.iaElement-6
                    //     left 311px
                    //     top 141px
                    //     width 53px
                    //     height 68px
                    .iaElement-title
                        display none
                    
.ui-dialog.ui-widget.info-popup
    font-family 'OpenSans'
    top 50px !important
    height 90% !important
    position absolute
    max-width 82.5rem
    -webkit-box-shadow 0px 2px 12px 7px rgba(0,0,0,0.13)
    -moz-box-shadow    0px 2px 12px 7px rgba(0,0,0,0.13)
    box-shadow         0px 2px 12px 7px rgba(0,0,0,0.13)