@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
#votingSlideDiv
    .mainWrapper
        .tnc
            &-container
                background-color $white
                max-width 22rem
                margin 6.3rem auto 0
                padding 1rem 2rem
                border-radius $radius
                overflow hidden
            &-instructions
                text-align center
                color $white
                font-size 1.5rem
                margin 0
                &__text
                    font-size 1.2rem
                    color $black !important
                    background-color transparent !important
                    padding 0
                    &:before
                        content '\f2bd'
                        font-family 'fa-solid-900'
                        display block
                        margin 1rem auto
                        font-size 4rem
                        color $darkgrey
            &-buttons.cl-buttons
                text-align center
                float none
                .cl-button--clear
                    display none !important
                .cl-button--submit
                    float none !important
            &-textarea-container
                margin 1rem auto
                text-align center
                input
                    box-shadow none
                    width 100%
                    padding 1rem
                    font-size 1.2rem
                    border-radius 2rem
                    text-align center
                .inputComponentMessageLength
                    font-size .8rem
                    text-align center
                    position static
                    width 100%
                    .textAreaAD__messageLength-counter
                        font-weight bold
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 600px)
    #votingSlideDiv
        .mainWrapper
            .tnc-container
                margin 3rem auto 0