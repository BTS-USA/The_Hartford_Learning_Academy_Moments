@import "common-rules.styl"
/*------------------------------------------------------------------------------------------------------------------------------------------*/
.bcc
    &-article
        margin-bottom 2px 
    &-bar
        background-color $white
    &-question
        background-color #EAE5DF
        border-radius 0
        border 1px solid #EAE5DF
        border-right none
        padding 1rem
        font-size 1.1rem
    &-answer
        background-color #EAE5DF
        border-radius 0
        border 1px solid #EAE5DF
        border-left none
        padding 1rem
        font-size 1.1rem
        .cl-bubble
            left 98%
/*------------------------------------------------------------------------------------------------------------------------------------------*/
@media screen and (max-width 768px)
    .bcc
        &-question
            border-radius $radius $radius 0 0
            border 1px solid $color-primary-grey
            border-bottom none
        &-answer
            border-radius 0 0 $radius $radius
            border 1px solid $color-primary-grey
            border-top none
@media screen and (max-width 600px)
    .bcc
        &-question
            padding .5rem
            font-size .8rem
        &-answer
            padding 1.5rem .5rem .5rem
            font-size .8rem