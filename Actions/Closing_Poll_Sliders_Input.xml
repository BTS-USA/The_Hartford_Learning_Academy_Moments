        "max": {
          "value": 5
        },
        "min": {
          "value": 0
        }
      }
    }
  },
  "buttons": [
    {
      "text": "!{Closing_Poll_Sliders_SingleSelectListSubmit}",
      "type": "submit",
      "message": "!{Closing_Poll_Sliders_SingleSelectListSubmitSaved}"
    }
  ],
  "scope": [
    "Closing_Poll_Sliders_PRIORITY_1_A",
    "Closing_Poll_Sliders_PRIORITY_2_A"
  ]
