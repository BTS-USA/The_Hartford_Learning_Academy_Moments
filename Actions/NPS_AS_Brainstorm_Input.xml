<Action disableDynamicVotes="false">
  <Component type="Input"><![CDATA[{
  "templateInEvent": "html/as_brainstormInput.dot",
  "css": "styles/as_brainstormInput.css",
  "header": {
    "bgimage": "/Wizer/Pages/Events/The_Hartford_Learning_Academy_Moments/images/headerGraphic.svg",
    "title": "!{NPS_BrainStormTitle}",
    "description": "!{NPS_BrainStormDescription}"
  },
  "instructions": "!{NPS_InputInstructions}",
  "questions": [
    {
      "binding": "1"
    }
  ],
  "bindings": {
    "1": {
      "bind": "db:NPS_INPUT_1",
      "render": "events/AS_Brainstorm/js/textAreaAD",
      "renderOptions": {
        "placeholder": "!{NPS_PlaceholderText}",
        "class": "cl-textarea",
        "maxCharacters": {
          "maxValue": 160,
          "class": "inputComponentMessageLength",
          "text": " !{NPS_CharactersRemaining}"
        },
        "clearButton": {
          "class": "inputComponentClear cl-button cl-button--clear",
          "text": "!{NPS_InputClear}"
        },
        "submitButton": {
          "class": "inputComponentSubmit cl-button cl-button--submit",
          "text": "!{NPS_InputSubmit}",
          "clearText": true,
          "message": "!{NPS_SavedText}"
        }
      }
    }
  },
  "scope": [
    "NPS_INPUT_1"
  ]
}]]></Component>
  <Component type="TextList" customJS="true"><![CDATA[{
  "version": "2.0",
  "templateInEvent": "html/as_brainstormTextlist.dot",
  "css": "styles/as_brainstormTextlist.css",
  "showCount": {
    "show": true,
    "yourCount": "!{NPS_Myentries}",
    "totalCount": "!{NPS_Totalentries}"
  },
  "deleteOwnIdea": true,
  "teamNameQuestion": "Team_Name",
  "questions": [
    {
      "binding": "NPS_INPUT_1"
    }
  ],
  "showAuthor": true,
  "showFilters": true,
  "restrictions": [
    "allVotes",
    "myVotes"
  ],
  "refresh": true,
  "maxLists": 1000,
  "scope": [
    "NPS_INPUT_1",
    "NPS_Team_Name"
  ]
}]]></Component>
</Action>