<Action disableDynamicVotes="false">
  <Component type="Input"><![CDATA[{
  "css": "styles/as_brainstormInput.css",
  "header": {
    "title": "!{Complexity_BrainStormTitle}",
    "description": "!{Complexity_BrainStormDescription}"
  },
  "instructions": "!{Complexity_BrainStormDescriptionA}",
  "questions": [
    {
      "binding": "1"
    }
  ],
  "bindings": {
    "1": {
      "bind": "db:Complexity_INPUT_1",
      "render": "events/The_Hartford_Learning_Academy_Moments/js/textAreaAD",
      "renderOptions": {
        "placeholder": "!{VUCA_PlaceholderTextA}",
        "class": "cl-textarea",
        "maxCharacters": {
          "maxValue": 300,
          "class": "inputComponentMessageLength",
          "text": " !{Complexity_CharactersRemaining}"
        },
        "clearButton": {
          "class": "inputComponentClear cl-button cl-button--clear",
          "text": "!{Complexity_clear}"
        },
        "submitButton": {
          "class": "inputComponentSubmit cl-button cl-button--submit",
          "text": "!{Complexity_submit}",
          "clearText": false,
          "message": "!{Complexity_saved}"
        }
      }
    }
  },
  "scope": [
    "Complexity_INPUT_1"
  ]
}]]></Component>
