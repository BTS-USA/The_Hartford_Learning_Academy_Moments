        },
        "clearButton": {
          "class": "inputComponentClear cl-button cl-button--clear",
          "text": "!{Apply_clear}"
        },
        "submitButton": {
          "class": "inputComponentSubmit cl-button cl-button--submit",
          "text": "!{Apply_submit}",
          "clearText": false,
          "message": "!{Apply_saved}"
        }
      }
    }
  },
  "scope": [
    "Apply_INPUT_1"
  ]
}]]></Component>
