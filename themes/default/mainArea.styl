        &:hover
            background-color $standard_button_hover
    .button-back
        background url("/Wizer/Pages/Events/WIB/Images/previous_btn.png") no-repeat center #FF8000
        cursor pointer
        color white
        font-size 16pt
        float left
        margin-top 10px
        clear both
        position fixed
        left 0px
        top 75%
        &:active
            background-color $standard_button_active
        &:hover
            background-color $standard_button_hover
    .button-next
        background-image url("/Wizer/Pages/Events/WIB/Images/next_btn.png") 
        background-repeat no-repeat 
        background-position center 
        background-color $standard_button
        background-size cover
        cursor pointer
        color white
        font-size 16pt
        float right
        margin-top 10px
        position fixed
        right 0px
        top 75%
        opacity .9
        &:active
            background-color $standard_button_active
        &:hover
            background-color $standard_button_hover
    .default-button,  .button-action, .ok-button
        position absolute
        background-color $standard_button
        cursor pointer
        color #fff
        font-size 18px
        text-align center
        vertical-align middle
        padding 8px 30px
        right 0px
        bottom 0px
        height auto
        width auto
        border 10px solid #7A7A7A
        border 10px solid rgba(0, 0, 0, 0)
        box-sizing border-box
        background-clip padding-box
        border-radius 12px
        &:active
            background-color $standard_button_active
        &:hover
            background-color $standard_button_hover
    .button-close, .x-button
        display none
        cursor pointer
        color white
        padding 0 20px
        position absolute
        border none
        top 0px
        right 0px
        background-image url('/Wizer/Pages/Events/WIB/Images/close_window_0.png')
        width 13px
        height 44px
        background-repeat no-repeat
        background-position 10px 16px
        border-radius 0px
        &.active
            display inline-block
        &:active
            background-color $standard_button_active
        &:hover
            background-color $standard_button_hover
    .button-disabled
        opacity .4
        background-color #666
        cursor initial
        &:hover, &:active
            background-color #666

// Responsive stylesheet
@media all and (max-width: 1000px)
    .mainarea #main-area
        min-width 0px
        #bottom
            display none
        #actions 
            bottom 0px
            text-align center
            margin 0px
            padding 0px
            .button 
                float none
                display inline-block
                width 19% 
                margin 0px
                padding 0px

        #bts
            display none
        #menus
            display none
    .datadashboard.template
        display none
    .infodashboard.template
        position absolute
        top 51px
        z-index 200
        bottom auto
        left 0px
        width 100%
        #timer-title, .timer, .user
            display none
        .progressBar
            width 100%
            height 4px
            rgba(200,200,200,1);
