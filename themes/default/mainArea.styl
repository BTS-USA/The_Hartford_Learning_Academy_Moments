    padding 0 
    background-repeat no-repeat

.button-skip
    cursor pointer
    float right
    margin 18px 0px
    padding 10px 20px 6px 15px
    color #FFF
    background-color #FF8000
    opacity 1
    border-radius 3px
    position fixed
    right 55px
    top 75%
    // overwrites redundant .button-skip code in the shared styles file
    height auto
    line-height 0
    &:hover
        background-color #FF5900
    span
        font 600 16px 'Open Sans'
        text-transform uppercase

.button-back[info-jump-button=back]
    background-image url('/Wizer/Pages/Events/SampleSimulation/Images/previous_btn.png')

.button-next[info-jump-button=next]
    background-image url('/Wizer/Pages/Events/SampleSimulation/Images/next_btn.png')

/* End common nav buttons */

/* Slider  */
.ui-slider { position: relative; text-align: left; }
.ui-slider .ui-slider-handle { position: absolute; z-index: 2; width: 1.2em; height: 1.2em; cursor: default; background: url('/Wizer/Pages/Events/SampleSimulation/Images/slider_btn.png'); width: 24px; height: 24px; }
.ui-slider .ui-slider-range { position: absolute; z-index: 1; font-size: .7em; display: block; border: 0; background-position: 0 0; }

.ui-slider-horizontal { height: .8em; }
.ui-slider-horizontal .ui-slider-handle { top: -.3em; margin-left: -.6em; }
.ui-slider-horizontal .ui-slider-range { top: 0; height: 100%; }
.ui-slider-horizontal .ui-slider-range-min { left: 0; }
.ui-slider-horizontal .ui-slider-range-max { right: 0; }

.ui-slider-vertical { width: .8em; height: 100px; }
.ui-slider-vertical .ui-slider-handle { left: -.3em; margin-left: 0; margin-bottom: -.6em; }
.ui-slider-vertical .ui-slider-range { left: 0; width: 100%; }
.ui-slider-vertical .ui-slider-range-min { bottom: 0; }
.ui-slider-vertical .ui-slider-range-max { top: 0; }

/* customizations */

.ui-slider
    background #8F8F8F
    border-radius 15px
    .ui-slider-range 
        background #F75B08
        border-radius 15px
        z-index initial

.ui-slider-horizontal .ui-slider-handle
    top -0.6em
    border none
    cursor pointer
    z-index initial


