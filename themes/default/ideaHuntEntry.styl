// import component library mixins and variables
@import "shared/cl.styl"

$sliderHeight = 1.2*$px
// Mixins
input(size = 1.4)
    background white
    border none
    color $tundora
    font-size size*$px
    outline none
    padding 1*$px 1*$px
    resize none
    width 100% 
    @media screen and (max-width: 768px) {
        font-size 1.2*$px
    }
button($color = $apple)
    background $color
    boxSizing()
    border none
    color white
    cursor pointer
    font-size 1.4*$px
    height 4*$px
    line-height 4*$px
    outline 0
    text-align center
    text-transform uppercase
    width 110px
    &:hover 
        background lighten($color, 6%)
    &:active 
        background darken($color, 6%)

.rangeslider
.rangeslider__fill
    position relative
    background $codGray
    height $sliderHeight
    border-radius $sliderHeight
    margin-bottom .5*$px
    &--disabled
        opacity 0.4
        .rangeslider__handle
            cursor default
            pointer-events none
    &:active
    &:hover
        .rangeslider__value-bubble 
            opacity 1
    &:active
        .rangeslider__handle
            transform scale(1.1)
    &__fill
        background $corn
        overflow hidden
    &__handle
        background $cerulean
        cursor pointer
        float left
        width $sliderHeight*3
        height $sliderHeight*3
        position absolute
        top -($sliderHeight)
        border-radius 100%
        z-index 10
        &:hover
            transform scale(1.1)
    &__value-bubble 
        transition opacity .3s ease
        display block
        opacity 0
        position absolute
        bottom 100%
        margin-bottom 2.1*$px
        background white
        color $codGray
        border-radius .4*$px
        width 100%
        max-width 4*$px
        text-align center
        padding .1*$px
        margin-left -2*$px
        font-size 1.3*$px
        fontFamily(font = "OpenSans-Bold")
        &:before
        &:after 
            border-width 6px
            border-style solid
            border-color transparent
            content ""
            display block
            margin auto
            width 0
            position absolute
            left 0
            right 0 
        &:after
            border-top-color #fff
            border-bottom-width 0
            bottom -6px
    &__bar
        float left
        position relative
        width $sliderHeight*3
        text-align center
        oveflow hidden
        &:after
            content "|"
            height 1*$px
            font-size .8*$px


.ideaEntry
    &__table
        background $gray
        font-size 1.4*$px
        width 100%
        height 100vh
        overflow auto
        //position absolute
        //z-index 1
        &:after
            content ""
            display table
            clear both
        &:before
            content ""
            position fixed
            height 100%
            width 100%
            background $gray
            z-index -1
    // left part
    &__main
        background $mercury
        color $gray
        padding 4*$px
    
    &__videoplayer
        height 150px
    &__header
        margin-bottom 3*$px
        position relative
    &__footer
        clear both
    &__headline
        border none
        font-size 3.2*$px
        font-weight 300
        font-style normal
        line-height 1
        margin 0
        padding 0
        color $apple
        text-align left
        text-transform uppercas
        @media screen and (max-width: 768px) {
            font-size 2.2*$px
        }
        &-h2
            @extend .ideaEntry__headline
            margin-bottom 2*$px
            text-align left
            color white
        &-author
            font-size 1.2*$px
            color $gray
            padding .5*$px 0 0 0
            text-transform initial
        &__form
            margin-bottom 1.5*$px
    &__row
        margin-bottom 2.3*$px
    &__clear
        clear both
    &__label
        display block
        margin-bottom .5*$px
        font-size 1.6*$px
        color $gray
        font-weight 600
        &-white
            @extend .ideaEntry__label
            color white
            margin-bottom 4*$px
    &__label.mandatory:after
        color $monza
        content '*'
        position relative
        left 5px
    &__maxCharacters
        float right
    &__select
        input()
        color white
        background $tundora
        &[data-assignee]
            margin-bottom 25px
        &Category
            &--disable
                pointer-events none
    &__input
        input()
        &--disabled
            background-color #fff
    &__textarea
        border none
        color $codGray
        float none
        font-size 1.4*$px
        height 12*$px
        outline none
        padding 1*$px
        resize none
        width 100% 
        @media screen and (max-width 768px)
            font-size 1.2*$px
        &-comment
            @extend .ideaEntry__textarea
            
    &__date
        input()
        color white
        background $tundora url(media/img/calendar.png) no-repeat center right 1*$px
    &__progressSection
        margin-bottom 3*$px
        clear right
    &__isDraft
        width 30%
    &__media
        width 22.1*$px
        //height 12.6*$px
    &__control
        display inline-block
        margin-right 1*$px
        &:last-child 
            margin 0
    &__controls
        text-align right
        margin-bottom 1*$px
        overflow hidden
        .ideaEntry__control
            float right
            margin-left 1*$px
            margin-right 0
            &:last-child
                margin-left 0
        &--hide
            display none		
    &__button
        button($apple)
        &-add
        &-next
            button($cerulean)
        &-clear
        &-close
        &-delete
        &-deleteComment
        &-hideAssign
            button($sunsetOrange)
        &-showAssign
        &-assign
        &-save
            button($apple)
        &-confirmDelete
            button($sunsetOrange)
            width 5*$px
        &-addComment
            button($apple)
        &-addMedia
            background $cerulean url(media/img/novideo.png) no-repeat center center
            padding .5*$px
            width 7*$px
            height 6*$px
            cursor pointer
            overflow hidder
            text-indent -900px
            &--disabled
                cursor default !important
        &-add.inactive
            background-color $mediumGray
            pointer-events none
    &__deleteConfirmation
        display none
    &__savedMessage
        background $emerald
        color white
        padding 1.5*$px
        display none
    &__hiddenElement
        display none
    &__close
        position absolute
        right 1*$px
        top 1*$px
        background $codGray
        padding .7*$px
        cursor pointer
        &-button
            width 1.5*$px
            height 1.5*$px
            background url(media/img/close.svg) no-repeat center center
    &__popup
        display none
        position fixed
        position sticky
        z-index 4000
        left 0
        top 0
        right 0
        bottom 0
        .ideaEntry__table
            overflow-y auto
            overflow-x hidden
    &__right
        color white
        padding 4*$px
    &__instructions
        margin-bottom 4*$px
    &__instructiosCopy
        margin-bottom 4*$px
    &__comment
        background $tundora
        margin-bottom 1*$px
    &__commentParagraph
        padding 1*$px
    &__commentFooter
        background $codGray
        padding 1*$px
    &__commentNumber
        fontFamily(font = "OpenSans-Bold")
    &__commentAuthor
        color $cerulean
    &__ranks
        margin-bottom 4*$px
    &__rank 
        margin-bottom 3*$px
        clear both
    &__rankFooter
        color white
        font-size 1.1*$px
        position relative
    &__minValue
        float left
    &__maxValue
        float right
    &__bar
        margin-bottom .5*$px
        position relative
        &-container
            overflow hidden
            background $codGray
            border-radius $sliderHeight
            position relative
            height $sliderHeight
            position relative
        &-filled
            background $corn
            position absolute
            top 0
            bottom 0
            z-index 5
        &-bubble
            display block
            position absolute
            bottom 100%
            margin-bottom 1.1*$px
            background white
            color $codGray
            border-radius .4*$px
            width 100%
            max-width 4*$px
            text-align center
            padding .1*$px
            margin-left -2*$px
            font-size 1.3*$px
            &:before
            &:after 
                border-width 6px
                border-style solid
                border-color transparent
                content ""
                display block
                margin auto
                width 0
                position absolute
                left 0
                right 0 
            &:after
                border-top-color #fff
                border-bottom-width 0
                bottom -6px
    &__dropdown
        position relative
    &__dropdownList
        display none
        background-color $tundora
        color white
        list-style none
        margin 0
        padding 0
        position absolute
        left 0
        right 0
        top 3.9*$px
        z-index 10
    &__dropdownList
        li
            padding .6*$px 1*$px
            display block
    &__dropdownItem
        background $tundora url(media/img/progressIdeaHuntEntry.png) no-repeat top 6px right 5%
        &:hover
            background-color lighten($tundora, 10%)
            cursor pointer
    &__dropdownItem-1
        background-position right 5% top 6px
    &__dropdownItem-2
        background-position right 5% top -39px
    &__dropdownItem-3
        background-position right 5% top -84px
    &__dropdownItem-4
        background-position right 5% top -129px
    &__dropdownItem-5
        background-position right 5% top -174px
    &__dropdown-image
        background url(media/img/dropdown.svg) no-repeat right center
        width 20px
        height 20px
        float right
    &__dropdown-toggle
        boxSizing()
        color white
        fontFamily()
        padding 1*$px 1*$px
        width 100% 
        background-color $tundora
        cursor pointer
        @media screen and (max-width: 768px) {
            font-size 1.2*$px
        }
        &--disabled
            cursor default !important
            &:hover
                cursor default			
        &.ideaEntry__dropdownItem-1
            background-position right 5% top 10px
        &.ideaEntry__dropdownItem-2
            background-position right 5% top -35px
        &.ideaEntry__dropdownItem-3
            background-position right 5% top -80px
        &.ideaEntry__dropdownItem-4
            background-position right 5% top -125px
        &.ideaEntry__dropdownItem-5
            background-position right 5% top -170px

    &__errorMessage
        background red
        
    &-accordion
        .ideaEntry__header-row
            position relative
            padding 10px
            background $silver
            &:after
                content ""
                background url("media/img/plus.svg") no-repeat center center
                height 16px
                width 16px
                position absolute
                right 10px
                top 50%
                margin -8px 0 0 0
                cursor pointer
            label
                margin 0
            .ideaEntry__maxCharacters
                padding 1px 30px 0 0
        &__content
            display none
            margin 10px 0 0 0
        &--expanded
            .ideaEntry__header-row
                &:after 
                    background url("media/img/minus.svg") no-repeat center center
    @media screen and (max-width: 1200px)
        &__table
            .ideaEntry
                &__button
                    button($apple)
                    &-add
                    &-next
                    &-clear
                    &-close
                    &-delete
                    &-deleteComment
                    &-save
                    &-confirmDelete
                    &-addComment
                    &-addMedia
                    &-showAssign
                    &-hideAssign
                    &-assign
                        width 85px
                        margin-bottom .4*$px
                        font-size 1.3*$px
                        height 3.9*$px
    @media screen and (max-width: 768px)
        &__table
            .ideaEntry
                &__main
                    padding 2*$px 1*$px
                &__videoplayer
                        height 150px

                &__control
                    width 100%
                    display block
                &__button
                    button($apple)
                    &-add
                    &-next
                    &-clear
                    &-close
                    &-delete
                    &-deleteComment
                    &-save
                    &-confirmDelete
                    &-addComment
                    &-addMedia
                    &-showAssign
                    &-hideAssign
                    &-assign
                        width 100%
                        margin-bottom .4*$px
                &__dropdownList
                    top 3.6*$px
                    li 
                        padding .4*$px 1*$px
                &__dropdownItem
                    background-size 70px 130px
                &__dropdownItem-1
                    background-position right 5% top 7px
                &__dropdownItem-2
                    background-position right 5% top -23px
                &__dropdownItem-3
                    background-position right 5% top -52px
                &__dropdownItem-4
                    background-position right 5% top -81px
                &__dropdownItem-5
                    background-position right 5% top -110px
                &__dropdown-toggle
                    &.ideaEntry__dropdownItem-1
                        background-position right 5% top 12px
                    &.ideaEntry__dropdownItem-2
                        background-position right 5% top -18px
                    &.ideaEntry__dropdownItem-3
                        background-position right 5% top -47px
                    &.ideaEntry__dropdownItem-4
                        background-position right 5% top -76px
                    &.ideaEntry__dropdownItem-5
                        background-position right 5% top -105px
    .wizletIdeaHuntEntry .noEntry
          font-weight: bold
          font-size: 22px
          color: $cerulean   

[dir="rtl"]
	.ideaEntry
		&__maxCharacters
			float left
		&__dropdown-image
			float left
		&__date
			background $tundora url(media/img/calendar.png) no-repeat center left 1*$px
		&__row.cl-noLeft
			float right
			padding 0 0 0 10px
		&__row.cl-noRight
			float left
			padding 0 10px 0 0
		&__controls
			float right
		&__control
			float left
			&:last-child
				margin-left 1*$px
		&_mediaControl
			.ideaEntry__control
				float none
				margin-left 0
		&__headline, &__headline-h2
			text-align right
		&__dropdownItem-1
			background-position left 5% top 6px
		&__dropdownItem-2
			background-position left 5% top -39px
		&__dropdownItem-3
			background-position left 5% top -84px
		&__dropdownItem-4
			background-position left 5% top -129px
		&__dropdownItem-5
			background-position left 5% top -174px
		&__dropdown-toggle
			&.ideaEntry__dropdownItem-1
				background-position left 5% top 10px
			&.ideaEntry__dropdownItem-2
				background-position left 5% top -35px
			&.ideaEntry__dropdownItem-3
				background-position left 5% top -80px
			&.ideaEntry__dropdownItem-4
				background-position left 5% top -125px
			&.ideaEntry__dropdownItem-5
				background-position left 5% top -170px
		@media screen and (max-width: 768px)
			&__dropdownItem
                    background-size 70px 130px
                &__dropdownItem-1
                    background-position left 5% top 7px
                &__dropdownItem-2
                    background-position left 5% top -23px
                &__dropdownItem-3
                    background-position left 5% top -52px
                &__dropdownItem-4
                    background-position left 5% top -81px
                &__dropdownItem-5
                    background-position left 5% top -110px
                &__dropdown-toggle
                    &.ideaEntry__dropdownItem-1
                        background-position left 5% top 12px
                    &.ideaEntry__dropdownItem-2
                        background-position left 5% top -18px
                    &.ideaEntry__dropdownItem-3
                        background-position left 5% top -47px
                    &.ideaEntry__dropdownItem-4
                        background-position left 5% top -76px
                    &.ideaEntry__dropdownItem-5
                        background-position left 5% top -105px
            