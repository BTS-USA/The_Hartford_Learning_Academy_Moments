
//True constants - things that should be uniform literally everywhere. 
//Template top-title treatment
$main_heading_color = rgba(45, 109, 145, 1) 
$main_heading_height = 44px

//Content backgrounds:
$transparent_popup_background = rgba(45, 109, 145, .7)

//All templates:
$standard_template_positioning = absolute
$standard_template_z-index = 100

//Standard size templates:
$standard_total_height = 65% 
$standard_min_width = 650px
$standard_total_width = 80%
$standard_gutter_width = 10%
$standard_top_position = 15%
$standard_entry_width = 60%
$standard_width_remaining_after_entry = 37%
$standard_entry_heading_height = 30px
$standard_left_content_width = 650px

//Wide content:
$wide_min_width = 850px

//Color Palette:
$hiltonColor1 = rgba(171, 132, 34, 1)
$transColor1 = rgba(171, 132, 34, .66)
$hiltonColor2 = rgba(105, 124, 140, 1)
$hiltonColor3 = rgba(165, 194, 198, 1)
$hiltonColor4 = rgba(119, 94, 108, 1)
$hiltonColor5 = rgba(160, 100, 79, 1)
$hiltonColor6 = rgba(81, 31, 53, 1)
$hiltonColor6Hover = #9e2954
$hiltonColor7 = rgba(130, 130, 130, 1)
$hiltonColor8 = rgba(88, 88, 88, 1)
$hiltonColor9 = rgba(170, 168, 102, 1)
$hiltonTextColor1 = #515f6f


//Specific heights for specific content:
$standard_video_height = 435px
$standard_info_with_image_height = 406px

//Reverse layout templates:
$reverse_entry_width = 40%
$reverse_left_content_width = 60%

//Compact width templates:
$compact_gutter_width = 20%
$compact_content_width = 60%

//Small templates:


//Mini templates:
$mini_min_height = 360px
$mini_total_width = 30%
$mini_min_width = 330px
$mini_gutter_width = 35%

$standard_text_color = #005A85
$standard_text_text-align = left
$standard_text_margins = 18px 18px
$standard_text_font-size = 14px

$popup_text_text-align = center

$position = absolute
$total_height = auto
$total_width = 100%
$gutter_width = 10%
$top_position = 0px
$left_position = 0px

