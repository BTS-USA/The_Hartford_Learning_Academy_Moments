//import variables and mixins
@import "shared/cl.styl"

$primaryBlue = #6cbee5
$borderBottomGray = #d3d3d3
$lightGrayText = #a9a9a9

.fileUploadDownload
	max-width 40%
	margin 0 auto
	@media screen and (max-width 767px)
		max-width 94%
	@media only screen and (min-device-width 768px) and (max-device-width 1024px)
		max-width 50%
	&--assessor
		max-width 100%
.fileUpload--details
	color $lightGrayText
	font-size 0.8rem
.fileUpload
	&-container
		margin-top 30px
	&__browseBtn
		position absolute
		top -12px
		right 0
		&--disable
			pointer-events none
	&__attachmentTextCont
		font-weight 600
		line-height 1.75
	&__attachment
		position relative
		&-fileinfo
			display flex
		&-fileDetails
			width 80%
		&-delete
			color $black50
			text-align right
			font-size 1.175rem
		&-btnCont
			padding 0 0 0 18px
		&-btn
			color $black50
			background none
			padding 0
			text-decoration none
			cursor pointer
			font-size 1rem
			&:before
				padding 0 10px 0 0
		&-listContainer
			padding 10px 18px
		&-file
			float none
			border-bottom 2px solid $borderBottomGray
			padding 5px 0
			&:last-child
				border-bottom none
				padding-bottom 15px
		&-filelist
			color $black70
		&-detailsCont
			width 20%
			flex-direction row-reverse
			align-items center
			display flex
			a
				cursor pointer
		&-insertBtn
			vertical-align middle
			padding .625rem .75rem
			min-width 6.875rem
			margin-bottom 5px
			font-size .875rem
			font-weight 400
			line-height 1.42857143
			color $white
			text-align center
			white-space nowrap
			cursor pointer
			user-select none
			background-image none
			border none
			outline none
			background-color $cerulean
	&__uploadListCont
		background $white60
		padding 15px 15px 30px 10px
		border 2px solid $primaryBlue
	
	&__noAttachment
		background $white60
		height 50px
		padding 15px 25px
		font-size 0.9rem
		color $lightGrayText
	&-modal
		display none
		opacity 1
		left 0
		position absolute
		top 0
		text-align center
		background-color rgba(0,0,0,0.55)
		&__dialog
			position absolute
			top 50%
			left 50%
			background-color #fff
			box-shadow none
			transform translate(-50%,-50%)
			-webkit-transform translate(-50%,-50%)
			@media (max-width 768px)
				width 90%
				
		&__buttons
			float none
			&--cancel
				background $gray
		&__body
			padding 30px 50px 20px
	&-loader
		display none	
		position absolute
		width 100%
		height 100%
		top 0px
		left 0
		padding-top 28px
		transform none
	&-loaderCont
		height 50px
		width 50px
		background-size 100%
		position absolute
		top 40%
		right 46%
		margin 0
		transform translateY(-50%)
	
	&-loaderSubCont	
		position relative
		width 100%
		height 100%
		background-color rgba(255,255,255,0.5)
		
.fileDownload
	&__attachment
		&-text
			width 100%
			background $primaryBlue
			color $white
			padding 10px
			font-size 1rem
		&-file
			float none
		&-container
			position unset
			background $mercury
		&-cont
			@media screen and (max-width 1023px)
				position absolute
				transform translate(25%,25%)
	&-listCont
		background $white60
		max-height 440px
		overflow-x auto
		font-size 1rem
		
	&-list
		border-bottom 2px solid $borderBottomGray
		color $black70
		margin 0 15px
		padding 15px
		display flex
		&:last-child
			border-bottom none
		&__fileNameCont
			width 70%
		
		&__fileDetailsCont
			display flex
			align-items center
		
		&__fileDetailsCont
			width 30%
			align-items center
			display flex
			flex-direction row-reverse
			a
				padding 0 15px
				cursor pointer
				font-size 1.175rem
				color $black50
		&__removeIcon
			color $black50
			right 0
			cursor pointer
			font-size 1.175rem
			&--disable
				pointer-events none

.jFiler-items .pull-left
	float none


.attachbtn
	&:before
		font-family clIcons
		display inline-block
		font-style normal
		speak none
		-webkit-font-smoothing antialiased