@import 'normalize' // normalize.css v3.0.2
@import 'fonts' // Default font is OpenSans
@import 'cl.styl'// Variables and mixins
@import 'grid' // Modified bootstrap grid system

*,
*:after,
*:before
    margin 0
    padding 0
    box-sizing border-box

ul
    padding 0 0 0 30px
html
    text-rendering optimizeLegibility

body 
    font-family OpenSans, Arial, "Helvetica Neue", Helvetica, sans-serif
    font-size 1.6*$px
    line-height 1.4
    color $codGray
    line-height normal
    
    .phonegap-upload
        &__container
            position fixed
            z-index 1000
            width 200px
            padding 20px
            left 50%
            margin-left -110px
            top 250px
            background #333
            color #fff
            border 1px solid #999
            border-radius 6px
        &__status
            font-size 18px


input[type="text"], textarea, :focus
    outline 0px
input[type="text"],input[type="password"], textarea
    -webkit-appearance none
    border-radius 0

// states
.cl--appear
    opacity 1
    transition(opacity 0.5s ease-in 1.25s)
[class*="cl-"] [class $="--fade"]
    opacity 0
    transition(opacity 0.25s ease-out)

.cl-icon
    font-family "clIcons"
    display inline-block
    font-style normal
    speak none
    -webkit-font-smoothing antialiased

