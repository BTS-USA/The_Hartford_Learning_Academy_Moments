.gw-icon
    font-family "gwclIcons"
    display inline-block
    font-style normal
    speak none
    -webkit-font-smoothing antialiased
    
.gw-icon--back:before
    content "\e920"

.gw-icon--glossary:before
    content "\e90b"
      
.gw-icon--visited:before
    content "\e918"

.gw-icon--completed:before
    content "\e916"

.gw-icon--info:before
    content "\e924"
    
.gw-icon--lock:before
