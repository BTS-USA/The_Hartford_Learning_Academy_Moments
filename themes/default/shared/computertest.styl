    @import "componentlibrary.styl"
    html
        overflow -moz-scrollbars-vertical
        line-height 1.5em

    p, li
        font-size 1.6*$px
        color $codGray
        margin 0 0 0.5em 0
    a:link
        font-size 1.6*$px
        color $deepCerulean
    a:visited
        //color darken($deepCerulean, 40%)
        color #00496a
    ul, ol
        padding 0 0 0 20px
    h2, h3, h4, h5, h6
        margin 0 0 10px 0
        font-weight 600
        line-height 1.4em
    h1
        font-size 3.6*$px
    h2
        font-size 3*$px
    h3
        font-size 2.4*$px
        color $deepCerulean
    h4
        font-size 1.8*$px
    h5
        font-size 1.4*$px
    h6
        font-size 1.2*$px
    .border_right
        border-right 1px solid #e6e6e6
    .BeginTest
        -moz-box-shadow inset 0px 1px 0px 0px #ffffff
        -webkit-box-shadow inset 0px 1px 0px 0px #ffffff
        box-shadow inset 0px 1px 0px 0px #ffffff
        background -webkit-gradient( linear, left top, left bottom, color-stop(0.05, #ededed), color-stop(1, #dfdfdf) )
        background -moz-linear-gradient( center top, #ededed 5%, #dfdfdf 100% )
        background-color #ededed
        -moz-border-radius 6px
        -webkit-border-radius 6px
        border-radius 6px
        border 1px solid #777777
        display inline-block
        color #002d56
        text-decoration none
        font-family Verdana
        font-size 15px
        font-weight bold
        padding 6px 24px
        text-decoration none
        text-shadow 1px 1px 0px #ededed


    .style3
        color #ADB500
        font-weight bold
        font-size 12px
        font-family Verdana, Arial, Helvetica, sans-serif

    .style4
        color #ADB500
        font-size 14px
        font-family Verdana, Arial, Helvetica, sans-serif

    .style5
