// import vavriables and mixins
@import "shared/cl.styl"
.rr
    page-break-inside avoid
.rrc
    &-grade
        padding 30px 0
        background-color lighten($mercury, 40%)
        border-bottom 1px solid silver
        &__header
            font-size 1.6*$px
            font-weight 100 
            color $cerulean
            text-align center
            margin 0 15px 10px 15px
        &__menuhold
            text-align center
        &__menu
            position relative
            display inline-block
            vertical-align middle
            padding 0 15px
            @media (min-width:768px)
                padding 0
        &__button
            background-color $mercury
            text-align center
            color $gray
            padding 5px 15px
            border 1px solid darken($silver, 10%)
            display inline-block
            white-space nowrap
            min-width calc(100% - 30px)
            @media (min-width:768px)
                min-width 120px
            .cl-vp[max-width~="480px"] &
                min-width calc(100% - 30px)
                display block
            & ~ ^[2]
                @media (min-width:768px)
                    margin-left -6px
                .cl-vp[max-width~="480px"] &
                    margin-left 0
            &:last-child
                margin-left -6px
                @media (min-width:768px)
                    border-radius(0 6px 6px 0)
                .cl-vp[max-width~="480px"] &
                    border-radius(0)
                    margin 0
            &:first-child
                @media (min-width:768px)
                    border-radius(6px 0 0 6px)
                .cl-vp[max-width~="480px"] &
                    border-radius(0)
            &--selected
                background-color $emerald
                color #fff

    &-matrix
        &__cell
            padding 15px 10px
            border-top 1px solid $silver
            text-align center
            &--header
                background-color $deepCerulean
                color #fff
                text-align center
                font-size 1.2*$px
                vertical-align middle
                border 0
            &--blank
                min-width 150px
                background-color transparent
            &--oddheader
                background-color darken($deepCerulean, 10%)
            &--oddcell
                background-color $mercury
            &--marked:after
                content "\f115";
                color $deepCerulean
                font-family "clIcons"
        &__table
            margin-bottom 30px
            float left
            padding 0 15px 0 0
            @media (min-width:992px)
                padding 0
            @media (min-width:992px)
                table-layout fixed
        &__label
            color $gray
            font-size 1.2*$px
    &-body
        background-color #fff
        padding 30px 15px
        overflow auto
    &-summery
        &__subheader
            font-size 1.6*$px
            font-weight 400
            margin-bottom 0.5em
            color $cerulean
        &__text
            color gray
            border 0
            background-color transparent
            width 100%