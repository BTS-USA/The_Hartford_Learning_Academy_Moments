	width 5px
	background-color #fff


::-webkit-scrollbar-thumb
	border-radius 6px
	background-color #6d747e


ul.meeting-tabs
	margin 0px
	padding 0px
	list-style none
	text-align center

ul.meeting-tabs li
	background #ffff
	color #222
	display inline-block
	padding 10px 15px
	cursor pointer
	margin-bottom 5px
	border-radius 10px    

ul.meeting-tabs li.current
	background #ededed
	color #222

.meeting-tabs-content
	display none
	background #ededed
	padding 15px

.meeting-tabs-content.current
	display inherit
   
.border
	border-radius 10px