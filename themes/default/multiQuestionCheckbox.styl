.wizletMultiQuestionCheckbox
    ul {
	    margin-left: 25px;
	    margin-bottom: 25px;
    }
    input {
        margin-right: 10px;
    }
    li {
        list-style-type: none;
    }
    p {
        margin: 10px;
    }
    .costQuestionValue {
        padding: 10px;
        background-color: red;
    }
    .multiGrid
        li { 
            display: inline-block; 
            margin: 25px;
            background-color: antiquewhite;
            color: black;
            input[type=checkbox] {
                display: none;
            }
            label {
                display: block;
                height: 150px;
                width: 200px;
                padding: 25px;
            }
        }
        li.selected {
            border 3px solid #blue;
            background-color: lightblue;
        }
        li.deselected.disabled {
            background-color: lightgray;
            color: darkgray;
        }
