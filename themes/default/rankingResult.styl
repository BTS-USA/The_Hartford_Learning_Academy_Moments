.wizletRankingResult
{
    *padding-bottom: 30px;
}

.wizletRankingResult

    #contentBox  
    {
	    padding:3px 13px 30px;
	    float: none;
    }


    .RankingResult_TableDiv  
    {
	    height: auto;
	    overflow-x:hidden;
    }

    .RankingResult_RowEven,
    .RankingResult_RowOdd,
    .RankingResult_Row_Header
    {
	    background-color: transparent;
    }

    .RankingResult_RowEven td
    {
	    background:  transparent url('/Wizer/Content/WizletResources/Shared/media/img/bg_black_50.png'); /* bg_black_50.png */
    }

    .RankingResult_RowOdd td
    {
	    /*background:  transparent url('/Wizer/Content/WizletResources/Shared/media/img/bg_white_25.png');*/
    }

    .RankingResult_Row_Header th
    {
	    background-image: none;
	    font-size: 14px;
	    font-weight: bold;
	    text-transform: uppercase;
    }

    .RankingResult_Cell_Headertext
    {
	    text-align: left;
    }

    .horisontalBarChartLegend
    {
	    display: none;
    }

    .horisontalBarChart26 
    {
	    width: 150px;
	    float: none;
	    *margin: 4px 8px;
    }

    .horisontalBarChart
    {
	    width: 180px;
    }

    .RankingResult_Cell_Rank  
    {
	    text-align: right;
	    width:31px;
	    padding-right: 20px;
    }

    .RankingResult_Cell_Text
    {
	    width: 100%;
	    *padding-top: 1px;
	    *padding-bottom: 1px;
    }

    .mainContent  
    {
	    margin-bottom:31px;
    }

    .horisontalBarChart26Right
    {
        *position: static;
    }

    .horisontalBarChart26
    {
        *position: static;
    }

    .horisontalBarChart26Left
    {
        *position:static;

    }



