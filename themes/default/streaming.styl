.wizletStreaming
    overflow hidden
    margin 0 20px 20px 20px

    h1
        border-bottom 0
        padding-bottom 0

    .cinema,
    .sidebar
        float left
        box-sizing border-box

    .cinema
        width 72% //IE8
        width calc(75% \- 20px)
        margin-right 20px

        .provider
            padding: 20px
            background #000 //IE8
            background rgba(255, 255, 255, 0.15)
            border-radius 4px

        .button
            float left
            margin 20px 20px 0 0
            padding 10px
            background #000
            background rgba(255, 255, 255, 0.15)
            border-radius 4px

    .sidebar
        width 25%

        .logo
            margin-top 20px
            img
                width 100%

        .comments
            overflow hidden
            padding 20px
            background #000 //IE8
            background rgba(255, 255, 255, 0.15)
            border-radius 4px

            textarea
                width 100%

            .designedButton
                display none!important //Currently gets overriden when embedding wizlet

            .addCommentButton
                display block!important //Currently gets overriden when embedding wizlet
                float right
                outline 3px solid rgba(255, 255, 255, 0.20)
                text-transform uppercase
                font-weight bold
                padding 10px
                border 0
                color #fff
                background green
                background rgb(51, 153, 51)
                margin-top: 20px
                cursor: pointer 
