
@import "shared/cl.styl"

.menunavigationpopup
	overflow hidden
	background none
	background-color #E6E6E6
	.commandOutput
		height 100%
		padding-top 0
		padding-left .5em
		.mainContentWrapper
			height 100%
			.mainContent
				height 100%
			.confParticipantList
				width 100%
				height 100%
				font-size 1.4*$px
				.legends
					margin-bottom 0
					padding 5px
					text-align center
					a
						display inline-block
						text-decoration none
						padding 4px
						margin 2px 0
						background-color #cccccc
						height 20px
						width 20px
						border-radius 3px
						text-align center
						line-height 20px
				.participantsContainer
					margin-top 0
				.header
					header();
					margin-bottom 2.125rem
					padding 1rem
					h1
						headline1();
						font-size 1.5rem
				.participants
					&Container
						width 100%
						height 75%
						overflow-y auto
						border: 1px solid #334d5c
						margin-top 10px
				.participant
					&Row
						clear both
						overflow hidden
						padding 6px
						line-height: 22px
						&:nth-child(even)
							background-color mercury
						&:nth-child(odd)
							background-color white
						&Header
							overflow hidden
							background-color #334d5c
							color: white
							padding: 6px
					&Name
						font-weight bold
					&Email a
						text-decoration none
						color #2E76A0
					&Phone a
						text-decoration none
					&Name
					&Phone
					&Office
					&Email
						float left
						font-size 12px
						word-wrap break-word
						padding 0 1*$px

@media screen and (max-width: 767px)
	.hidden-xs
		display none !important
	.visible-xs
		display block
	.dataPrefix
		display block
		width 50px
		float left
	.participant
		&Name
			font-weight bold
			border-top 1px solid #ccc
	.menunavigationpopup .commandOutput .mainContentWrapper .confParticipantList .participantsContainer .participantRow
		padding 0
		&:nth-child(even)
			background-color white
		&:nth-child(odd)
			background-color white
		.participantName
			background-color mercury
	.menunavigationpopup .commandOutput .mainContentWrapper .confParticipantList .legends
		text-align left
			
@media screen and (min-width: 767px)
	.hidden-xs
		display block
	.visible-xs
		display none !important
	.dataPrefix
		display none
@media screen and (max-width: 768px)
	.menunavigationpopup .commandOutput .mainContentWrapper .confParticipantList .legends
		text-align left