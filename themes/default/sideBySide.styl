// import component library mixins and variables
@import "shared/cl.styl"
.bodySideBySide, .bodySideBySidePhonebank
    #votingSlideDiv
        padding 0
.sbsc
    .cc-videobox__subscriber
        .OT_subscriber
            min-width 100px
            width 20%
            max-width 320px
    .cc-videobox__publisher
        width 15%
        min-width 100px
        max-width 180px
    .cc-videobox__wrapper
        padding-bottom 0
        padding 0
    height calc(100vh - 50px)
    width 100vw
    position relative
    overflow hidden
    &-pagebreak
        page-break-before always
    @media (min-width 1024px)
        max-width 100% // for screens larger then 1024px (ipad) screen will show background
        margin 0 auto
        height calc(100vh - 50px)
    @media (min-width 768px) and (max-width 1024px)
        max-width 100%
        margin 0 auto
        // height calc(88vh - 50px) //for screens larger than 768px and less than 1024px (ipads) height is reset
    select::-ms-expand
        display none
    
    .coc-header--closed .coc--modified
        border 0
    .coc-header--open.coc--modified
        border 0

    .coc-note__activity
        .coc-note__data-text--disabled
            width 90%

    &-leftcol, &-rightcol
        height 100%
        &__viewport
            padding 10px 0px 10px 10px
            height 30px
            font-size 1.6*$px
            background-color $codGray
            color #ffffff
    &-leftcolonback
        z-index -1
    &-rightcol
        z-index 15
        
    &-userrow
        padding 5px 0px 5px 10px
        text-transform uppercase
        height 30px
        font-weight bold
        background-color $codGray
        &__title
            font-size 1.4*$px
            color #fff
            margin 0
        
    &-viewport
        padding 10px 0px 10px 10px
        font-size 1.6*$px
        background-color $codGray
        color #ffffff
        height 50px
        &__header
            padding 10px 0
            float left
        &__title
            font-size 1.6*$px
            font-weight 100
            padding 2px 0
            text-transform uppercase
            float left
        &__select
            margin 0 0 0 10px
            padding 0
            float left
            width 75%
            height auto
            border 0
            overflow hidden
            @media (max-width 768px)
                width 65%

        &__selections
            background-color #fff
            height 27px
            cursor default

        &__rootNode
            overflow hidden
            position relative
            height 100%

        &__rootNodeText
            float left
            color #000
            padding 3px 1px 0px 10px

        &__rootNodeIcon
            background url("../../Shared/media/img/downDropBlue.png")
            background-size 27px 27px
            height 27px
            width 27px
            position absolute
            right 0

        &__options
            overflow hidden
            color #000
            position relative
            z-index 10000
            background #fff
            margin 1px 0 0 0
            border 1px solid $gray
            display none
            &--open
                display block
                @media screen and ( max-height: 800px )
                    max-height 400px
                    overflow auto
                @media screen and ( max-height: 600px )
                    max-height 350px
                    overflow auto

        &__viewportOption
            padding 5px 10px
            cursor default
            &:hover
                background-color $cerulean
                color #fff
            &--selected
                background-color $cerulean
                color #fff

    &-window
        height calc(100% - 50px) //50px is height of viewport
        position absolute
        width 100%
        top 50px
        z-index auto
        transition(all 0.5s ease 0.15s)
        &__header
            padding-left 10px
            height 37px
            font-size 1.6*$px
            background-color $cerulean
            color #ffffff
            border-bottom 2px solid $mercury
        &__title
            font-size 1.44*$px
            line-height 1em
            padding 10px 0
            width calc(100% - 38px)
            float left

            @media (min-width 1024px)
                font-size 1.6*$px
                width calc(100% - 40px)
        &__body
            min-height 20px
            overflow-y auto
            &--left
                height calc(100% - 70px)
            &--hideVideo
                height calc(100% - 40px)
            &--left
            &--right
                overflow auto
                border-right 1px solid $gray

            &--right
                height calc(100% - 188px)
            &--hideNote
                height calc(100% - 40px)			       
            &--hideBody
                display none
            &--showBody
                display block
            &--withVideo
                height 45%
            &--adjustHeight
                height calc(100% - 70px)
            @media (min-width 768px)
                .ec
                    height calc(90vh - 100px)
                .cc
                    height calc(100vh - 170px)
            .cc
                &-lp
                &-rp
                    height 100%

        &__rightCont
            height 100%
            overflow auto
            -webkit-overflow-scrolling touch
            
        &__notes
        &__video
            position relative
            bottom 0
            //overflow hidden
            width 100%
            z-index 10
            &--expand
                height 100%
        &__video
            height calc(65% - 45px)
            .cc-videobox
                &__buttons
                    position absolute
                    bottom 10px
                    width 100%
                    z-index 500
                    text-align center
                    border-top 1px solid $silver
                    background-color $mercury
                    padding 5px
                    .cc-button
                        &__start
                            button($apple)
                            padding 5px 15px
                        &__forceFallback
                            button($tundora)
                            padding 5px 15px
                            &::before
                                font-family "clIcons"
                                content: "\f125"
                                display inline-block
                                font-size 0.75rem
                #exercisesQuestion
                    height calc(100% - 70px)
                    overflow-y auto

                &__message, &__calldescription, &__calldescriptionheader
                    text-align center
                    color gray
                &__message
                    padding 45px 0
                    &::before
                        font-family "clIcons"
                        content "\f129"
                        display inline-block
                        padding 0 15px
                        font-size 1.4rem
                        position relative
                        top 3px

                &__exerciseList
                    margin-bottom 50px
                
                &__calldescriptionheader
                    padding 10px 0 5px 0
                    font-weight bold
                    font-size 1.1rem
                    color $codGray

                &__calldescription
                    width 300px
                    background-color $white
                    margin 0 auto
                    word-wrap break-word
                    padding 5px 15px
                    margin-top 5px
                    color #1e1e1e
                    font-size 0.9rem
                    cursor pointer
                    &:hover
                        background-color $cerulean
                        color $white
                &__videoOptions
                    max-width 265px
                    margin 0 auto
                &__option
                    font-size 0.8rem
                    font-weight bold
                    text-align left
                    padding 0 5px 5px 5px
                    display inline-block

                &__checkboxContainer 
                    input[type="checkbox"]
                        display none
                    label
                        position relative
                        display inline-block
                        user-select none
                        /* 16px width of fake checkbox + 6px distance between fake checkbox and text */
                        padding-left 15px
                        font-size 0.65rem
                        cursor pointer
                        &::before, &::after
                            position absolute
                            content ""
                            /* Needed for the line-height to take effect */
                            display inline-block;
                        &::before
                            height 12px
                            width 12px
                            border 1px solid
                            left 0px
                            /* (24px line-height - 16px height of fake checkbox) / 2 - 1px for the border to vertically center it. */
                            top 1px
                        &::after
                            height 4px
                            width 8px
                            border-left 1.5px solid
                            border-bottom 1.5px solid
                            transform rotate(-45deg)
                            left 2px
                            top 4px
                    label.disabled
                        opacity 0.6
                        cursor not-allowed

                &__checkboxContainer input[type="checkbox"] + label::after
                    content none
                &__checkboxContainer input[type="checkbox"]:checked + label::after
                    content ""
                
                &__alertBoxContainer
                    height calc(100% - 70px)
                    overflow-y auto
                &__alertBox
                    background $white
                    width 100%
                    max-width 425px
                    box-shadow(3px 3px 15px $silver)
                    text-align center
                    color $codGray
                    margin 0 auto
                    margin-top 2.5rem
                    margin-bottom 2.5rem

                    &--unableTo, &--contactInfo
                        padding 15px 25px
                        max-width 425px
                        font-size 1em

                    &--unableTo
                        img
                            margin-top 20px
                        h1
                            margin 0
                            font-size 1em
                            color $bloodRed
                        p
                            color $gray30
                            font-size 0.875rem
                            font-style italic
                            margin 5px 0 0 0
                    
                    &--contactInfo
                        padding 0 25px 15px 25px
                        a
                            color $royalBlue
                            font-size 0.875rem
                        ul, li
                            margin 0
                            padding 4px 0
                            list-style none
                        label
                            font-weight bold

        &__noteHeader
        &__videoHeader
            background-color $cerulean
            height 30px

        &__noteExpandBtn, &__noteCollapseBtn
            float right
            width 30px
            height 100%
            background-color #7fc1e7
            font-family "clIcons"
            padding 4px 0 0 5px
            cursor pointer
            
        &__noteExpandBtn
            &::after
                content "\f120"
                font-size 2*$px
                color #fff

        &__noteCollapseBtn
            margin-right 5px
            &::after
                content "\f11f"
                font-size 2*$px
                color #fff    

        &__noteText
            color #fff
            float left
            margin 5px 0 0 10px

        &__noteBody
            width 100%
            resize none
            &--small
                height 0
                padding 0
            &--medium
                height 120px
                padding 10px
            &--large
                height 92%
                padding 10px
        &__videoBody
            width 100%
            resize none
            &--small
                height 0
                padding 0
                position relative
                overflow hidden
            &--medium
                height 80%
                padding 0
                position relative
                .cc-videobox__subscriber
                    .OT_subscriber
                        min-width 100px
                        width 20%
                        max-width 150px
                .cc-videobox__publisher
                    width 15%
                    min-width 100px
                    max-width 120px
            &--large
                height 92%
                padding 0
                position relative
            &--expand
                height 100%
        &__textAreaContainer
            height 100%
            div
                height 100%
 
        &--left
            left 0
            background-color $mercury
        &--right
            right 0
            background-color $mercury
        &--expand
            position absolute
            z-index 1000
            width 200%
            height 100%
            border 0
            top 0
            transition(all 0.5s ease 0.15s)
        &__button
            padding 10px
            height 100%
            display block
            float right
            background-color $codGray
            font-family "clIcons"
            &::after
                content "\f120"
                font-size 1.6*$px
            &--expand 
                &::after
                    content "\f11f"
                    font-size 1.6*$px
.fc
    &-modal
        position fixed
        top -100%
        left -100%
        opacity 0
        z-index 2000
        width 100%
        height 100%
        -webkit-transition opacity .5s ease-out
        -moz-transition opacity .5s ease-out
        -o-transition opacity .5s ease-out
        transition opacity .5s ease-out
        background-color rgba(255,255,255,0.55)
        &__dialog
            max-width 25%
            float none
            background-color $white
            margin 0 auto
            position relative
            top 50%
            -webkit-box-shadow 0 0 1px 1px rgba(30,30,30,0.55)
            -moz-box-shadow 0 0 1px 1px rgba(30,30,30,0.55)
            box-shadow 0 0 1px 1px rgba(30,30,30,0.55)
            -ms-transform translate(0,-50%)
            -webkit-transform translate(0,-50%)
            transform translate(0,-50%)
            @media (max-width 1024px)
                max-width 50%
        &__header
            padding-top 30px
            margin-bottom 5px
            background-color $white
        &__title
            margin-bottom 20px
            font-size 1.4rem
            color $cerulean
        &__body
            padding 0
            text-align center
        &__content
            padding 0 15px 5px 0
        &__footer
            padding-top 0
        &__buttons
            display flex
            float none
            margin-top 30px
        &--in
            opacity 1
            top 0
            left 0
            -webkit-transition opacity .5s ease-out
            -moz-transition opacity .5s ease-out
            -o-transition opacity .5s ease-out
            transition opacity .5s ease-out
            background-color rgba(0, 0, 0, 0.7)
    &-customButton
        flex 1
        padding 10px 0
        color $white
        cursor pointer
    &-customButton__no
        background-color $gray60
    &-customButton__yes
        background-color $apple

@media (max-width 1024px)
    .flowplayer .fp-header .fp-fullscreen
        position absolute
        top 65%
        right 0