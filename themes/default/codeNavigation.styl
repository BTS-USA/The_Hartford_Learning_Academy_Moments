// import variables and mixins
@import "shared/cl.styl"

// Input Component Styles
.cnc
    &-article
        overflow hidden
        display flex
        justify-content center

    &-footer
        margin 0 auto
        max-width 7.75rem
        padding 30px 0

    &-input
        width 90px
        font-size 40px
        border 0
        border-bottom 5px solid $cerulean
        float left
        margin 0 10px
        text-align center
        padding 20px 0
        -moz-appearance textfield
        &::-webkit-inner-spin-button,
        &::-webkit-outer-spin-button
            -webkit-appearance none
            margin 0
            
    &-error
        background #fff
        padding 10px 7px
        width 200px
        text-align center
        &Cont
            max-width 13rem
            margin 0 auto
            padding 30px 0
            display none
        &Msg
            color red

    &-button
        vertical-align middle
        width 120px
        margin 10px 5px 0 0 
        padding 10px 20px
        background $apple
        cursor pointer
        display none
        text-align center
        border-radius 10px
        &:last-child
            margin 10px 0 0 0
        &__image
            -webkit-transform   translate(0,50%)
            -o-transform        translate(0,50%)
            -moz-transform      translate(0,50%)
            -ms-transform       translate(0,50%)
            transform           translate(0,50%)
        &__text
            color #FFF
        &--selected
            background $cerulean
    &-button[data-buttondisabled="true"]
        display inline-block
        opacity 0.3
        cursor default
    &-button.active
        display inline-block

    &-show
        display block
               
    