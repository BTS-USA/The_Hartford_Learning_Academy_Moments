// import variables and mixins
@import "shared/cl.styl"

$highcharts-color-1 = #28324B
$highcharts-color-2 = #F00A3C
$highcharts-color-3 = #00B9FF
$highcharts-color-4 = #0050BE
$highcharts-color-5 = #FF41A5
$highcharts-color-6 = #A01882
$highcharts-color-7 = #5A198C
$highcharts-color-8 = #DFDF00
$highcharts-color-9 = #00BA4C
$highcharts-color-10 = #006D55

.lch
    &-container
        max-width 100%
    &-content
	    &-lineChart
	        &--container
                width 100%;
                height 550px;
	
	.highcharts
        &-color-0
            fill $highcharts-color-1
            stroke $highcharts-color-1
        &-color-1
            fill $highcharts-color-2
            stroke $highcharts-color-2
        &-color-2
            fill $highcharts-color-3
            stroke $highcharts-color-3
		&-color-3
            fill $highcharts-color-4
            stroke $highcharts-color-4
		&-color-4
            fill $highcharts-color-5
            stroke $highcharts-color-5
		&-color-5
            fill $highcharts-color-6
            stroke $highcharts-color-6
		&-color-6
            fill $highcharts-color-7
            stroke $highcharts-color-7
		&-color-7
            fill $highcharts-color-8
            stroke $highcharts-color-8
		&-color-8
            fill $highcharts-color-9
            stroke $highcharts-color-9
		&-color-9
            fill $highcharts-color-10
            stroke $highcharts-color-10

        &-stack-labels
            font-weight bold