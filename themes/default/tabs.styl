
@import './reporting.css'

.wizTypeTabs
  .wizletTabs
    min-height 100%
    min-height calc(100% \- 55px)

    .mainWrapper
        border 0

    #menuBar
      .ddsmoothmenu
          background none

        ul#rootMenu
          margin-top: 10px!important;
          padding-left: 50px;
          border-bottom: 1px solid #bbb;
          height: 39px

          li
            a
              display block
              color #999
              font-weight bold
              background #444
              position relative
              border-radius 3px 3px 0 0
              height 39px
              line-height 39px

            &.active
              a
                color: #fff;
                background: #2b2b2b;
                border: 1px solid #bbb;
                border-bottom: 0;

      #wizletFrame {
        top: 48px!important;
      }

