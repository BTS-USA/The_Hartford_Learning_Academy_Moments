        &-xs
            overflow hidden
            .tab
                display block
                font-size 1.6*$px
                font-weight 700
                width 100%
                float left
                padding 1*$px 2*$px
                margin 0
                color tundora
                background-color mercury
                border-bottom solid 1px gray
                box-sizing border-box
                &.active
                    background-color deepCerulean
                    border-bottom 0
                    border-top 0
