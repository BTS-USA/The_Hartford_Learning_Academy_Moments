                        height 0
                        width 0
                        cursor pointer
                        z-index 900
                        box-sizing content-box
                    &--active, &.active
                        background-color gray
                        border-bottom 1px solid gray
                        &:after
                            triangle(15px, 10px, 'top', silver)
            &__item
                float left
                width 100%
                background-color tundora
                padding-bottom 1px
                cursor pointer
            &__submenu
                &--active
                    display block
                &--bi
                    position relative
                    float left
                    width 100%
                    background-color silver
                    border-bottom 1px solid gray
                    padding 0
                    display none
                    &.active
                        display block
                &--tri
                    position relative
                    float left
                    padding 0
                    width 100%
                    background-color gray
                    margin 1px 0 0 0
                    display none 
            &__title
                color deepCerulean
                display block
                margin 0.5*$px
                padding 1*$px
                color deepCerulean
                overflow hidden
                position relative
            &__label
                margin 5px 0 
                cursor pointer
                float left
                font-size 1.6*$px
                color deepCerulean
                font-weight 400
            &__page
                width 100%
                height calc(100% - 3em)
                height -moz-calc(100% - 3rem)
                height -webkit-calc(100% - 3rem)
                display none
                &--showcontent
                    display block
        [class*='arrow'] 
            cursor pointer
        &-menu
            &__list
                &--bi
                    padding 0
        &-submenu
            list-style-type none
            line-height 1.4em
            padding 0
            border-bottom 0
            background-color silver
            color white
            position relative
            border-bottom 1px solid white
            &:after
                content ""
                clear both
                display block
            &--tri
                position relative
                background-color gray
                padding 0
                margin 0 0 1px 0
                display none
                &:after
                    content ""
                    clear both
                    display block
                &--active
                    display block
            &__list
                &--tri
                    padding 0
            &__label
                width 80%
                cursor pointer
                font-size 1.4*$px
                line-height 1.4em
                margin 0
                color gray
                background-color silver
                padding 1.4*$px 2*$px
                display inline-block
                &--active
                    display block
                &--bi
                    color gray
                    font-size 1.6*$px
                    font-weight 400
                    padding 10px 20px
                    cursor pointer
                &--tri
                    color silver
                    font-size 1.4*$px
                    font-weight 400
                    padding 15px 20px
                    cursor pointer
                    &--active
                        display block
            &__arrow
                float right
                z-index 100
                width 20%
                max-width 50px
                height 48px
                &--active
                    background-color gray
                    height 47px
                    &:after
                        triangle(15px, 10px, 'bottom', silver)
                &:after
                    position absolute
                    top 40%
                    right 40%
                    triangle(15px, 10px, 'top', tundora)
            &__ico
                &--tri
                    position absolute
                    top 0
                    right 0


    .shield
        position: absolute;
        width: 100%;
        height: 100%;
        z-index: 150;
        top: 0px;
        left: 0px;
        background-color rgba(0, 0, 0, 0.74902)

@media screen and (max-width: 767px)

        .hidden-xs
            display none !important
        .visible-xs
            display block


