            padding 1*$px 2*$px
            border 0
            box-sizing border-box
    .accordion
        width 100%
        overflow-y auto
        background-color mercury
        .accordionItem
            float left
            width 100%
            background-color tundora
            padding-bottom 1px
            cursor pointer

        .accordionItem .tabTitle 
            margin 0.2*$px 0 0 0
            vertical-align middle
            font-size 1.8*$px
            float left
            width -moz-calc(100% - 5rem)
            width -webkit-calc(100% - 5rem)
            width calc(100% - 5rem)
    
        .accordionItem .accordionPage
            width 100%
            height calc(100% - 3em)
            height -moz-calc(100% - 3rem)
            height -webkit-calc(100% - 3rem)
            display none
        .accordionItem.active .accordionPage
            display block
        .accordionTitle
            display block
            padding 1*$px
            background-color white
            color deepCerulean
            overflow hidden
            position relative

        .imageContainer 
            float right
            background url("media/img/plus.svg") no-repeat center center
            height 15px
            cursor pointer
            padding 10px 50px 0 0
            position absolute
            right 10px
            top calc( 50% - 7px )


        .imageContainer.expanded 
            background:url("media/img/minus.svg") no-repeat center center

        /* create a class that hides the text */
        .showcontent 
            display block

@media screen and (max-width: 767px)
    .tc
        .hidden-xs
            display none !important
        .visible-xs
            display block

[dir="rtl"]
	.tc
		&-acc__ico
			background url("media/img/plus.svg") no-repeat left center
			right 0
			left 15px
		&-acc__ico--expanded
			background url("media/img/minus.svg") no-repeat left center	
		&-submenu__arrow
			float left
		&-bar__tab
			float right
		&-bar__title
			float right
		&-bar__arrow
			right auto
			transform rotate(180deg)
			&--active
				-webkit-transition: all 1s;
				transition: all 1s;
				-webkit-transform: rotate(0.25turn);
				transform: rotate(0.25turn);
