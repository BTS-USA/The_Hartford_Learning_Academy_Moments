@import "../../Shared/css/cl.styl"
    .tc
        margin 0
        &-container
            .tc-expandCollapseCont
                text-align right
                .tc-expandCollapse
                    cursor pointer
                .tc-expandCollapseSign
                    display block
                    float right
                    background-color #6cbee5
                    font-family "clIcons"
                    padding 5px
                    margin-left 10px
                    cursor pointer
                    margin-top -2px

                .tc-expandCollapseSign.expand
                    &::after
                        content "\f114"
                        font-size 1.6*$px
                        color #fff

                .tc-expandCollapseSign.collapse
                    &::after
                        content "\f113"
                        font-size 1.6*$px
                        color #fff
                    
        &-bar
            margin 14px 0 0 0
            overflow hidden
            padding-top 14px
            padding-left 20px
            border-bottom 10px solid deepCerulean
            background-color silver
            &__tab
                display block
                font-size 1.6*$px
                line-height 1.4em
                float left
                height auto
                border-top 1px solid silver
                border-right 1px solid silver
                border-left 1px solid silver
                margin -3px 0 0 0
                color white
                background-clip border-box
                background-color #e6e6e6
                borderRadius(8px 14px 0 0)
                margin-right 30px
                position relative
                &:after
                    content ""
                    display block
                    height 0
                    width 0
                    border-right 29px solid transparent
                    float right
                    position relative
                    top 4px
                    right -26px
                    border-bottom 41px solid mercury
                    z-index 0
                &--active
                    color #ffffff
                    background-color deepCerulean
                    color #fff
                    height auto
                    border-top 1px solid deepCerulean
                    border-right 1px solid deepCerulean
                    border-left 1px solid deepCerulean
                    margin-top -3px
                    &:after
                        content ""
                        display block
                        height 0
                        width 0
                        border-right 29px solid transparent
                        float right
                        position relative
                        top 4px
                        right -27px
                        border-bottom 41px solid deepCerulean

            &__arrow
                triangle(10px, 15px, 'right', deepCerulean)
                top 17px
                right 5px
                position absolute
                cursor pointer
                z-index 900
                box-sizing content-box
                -webkit-transition all 0.5s
                transition all 0.5s
                transform-origin 50% 50%;
                &--active
                    border-left-color cerulean
                    top 17px
                    -webkit-transition all 1s
                    transition all 1s
                    -webkit-transform rotate(0.25turn)
                    transform rotate(0.25turn)
                    transform-origin 50% 50%;
                &--on
                  width 0
                  height 0
                  background:0
                  border-style solid
                  border-width 7.5px 0 7.5px 10px
                  border-color transparent transparent transparent #e6e6e6
                  transform-origin 50% 50%
            &__title
                margin 13px 20px 10px 20px
                cursor pointer
                float left
                font-size 1.6*$px
                color deepCerulean
                font-weight 400
                &--active
                    color #FFFFFF
        &-menu
            width 100%
            height 0px
            position relative
            z-index 1000
            left 0
            top 100%
            font-size 1.2*$px
            box-sizing border-box
            padding 0 0
            ul
                padding 0 0 0 0                

        &-submenu
            list-style-type none
            line-height 1.4em
            padding 0
            border-bottom solid 1px silver
            background-color mercury
            color white
            display none
            ul
                padding 0 0 0 0
            &__label
                cursor pointer
                font-size 1.4*$px
                line-height 1.4em
                color gray
                margin 1.4*$px 2*$px
                display inline-block
            &__arrow
                width 50px
                height 50px
                float right
                cursor pointer
                padding 1rem 1.375rem
                position relative
                top 25%
                &:after
                    content ""
                    display block
                    triangle(15px, 10px, 'bottom', deepCerulean);
                    margin 0 auto
                    position relative
                    top 25%
                    -webkit-transition all 0.5s
                    transition all 0.5s
                    transform-origin 50% 50%
            &__sub
                background-color silver
                display none
                padding 15px 30px 15px 30px
                margin 1px 0 0 
                border-bottom 0
                &--active
                    display block
                    margin 1px 0 0 
            &__ico
                margin 6px
                vertical-align middle
            &__sublabel
                font-size 1.4*$px
                margin 0
                width 80%
                cursor pointer
            &--active
                display block
            &__arrow
                width 50px
                height 50px
                float right
                cursor pointer
                padding 16px 22px
                position relative
                top 25%
                &:after
                    content ""
                    display block
                    triangle(15px, 10px, 'bottom', deepCerulean);
                    margin 0 auto
                    position relative
                    top 25%
                    -webkit-transition all 0.5s
                    transition all 0.5s
                    transform-origin 50% 50%
                    -webkit-transform rotate(0.5turn)
                    transform rotate(0.5turn)
                &--active
                    shape-rendering $crispEdges
                    background-color #ccc
                    &:after
                        content ""
                        display block
                        -webkit-transform rotate(0turn)
                        transform rotate(0turn)
                        background-color
                        margin 0 auto
        &-acctabs
            margin 0
            padding 0
            overflow hidden
        &-acc
            &__item
                position relative
                display block
                font-size 1rem
                font-weight 700
                width 100%
                float left
                padding 0
                margin 0
                color #4d4d4d
                border-bottom solid 1px silver
                box-sizing border-box
            &__label
                padding 10px 20px
                color deepCerulean
                cursor pointer
                background-color mercury
                &--bi
                    color gray
                    font-size 1.6*$px
                    font-weight 400
                    padding 10px 20px
                    cursor pointer
                &--tri
                    color silver
                    font-size 1.6*$px
                    font-weight 400
                    padding 10px 20px
                    cursor pointer
            &__arrow
                width 50px
                height 42px
                position absolute
                top 0
                right 0
                background-color mercury
                &:after
                    content ""
                    position absolute
                    right 30%
                    top 30%
                    triangle(15px, 10px, 'bottom', deepCerulean)
                    box-sizing content-box
                &--active, &.active
                    background-color silver
                    &:after
                        triangle(15px, 10px, 'top', deepCerulean)
                &--bi
                    height 43px 
                    width 50px
                    position absolute
                    top 0
                    right 0
                    background-color silver
                    border-bottom 1px solid gray
                    &:after
                        content ""
                        position absolute
                        triangle(15px, 10px, 'bottom', gray)
                        right 30%
                        top 30%
                        height 0
                        width 0
                        cursor pointer
                        z-index 900
                        box-sizing content-box
                    &--active, &.active
                        background-color gray
                        border-bottom 1px solid gray
                        &:after
                            triangle(15px, 10px, 'top', silver)
            &__menu
                position initial
                float left
                padding 0
                width 100%
            &__list
                &--bi
                    float left
                    border-bottom 0
                    list-style none
                    padding 0
                    margin 0
                &--tri
                    float left
                    border-bottom 0
                    list-style none
                    padding 0
                    margin 0
            &__submenu
                &--bi
                    position relative
                    float left
                    width 100%
                    background-color silver
                    border-bottom 1px solid gray
                    padding 0
                    display none
                    &.active
                        display block
                &--tri
                    position relative
                    float left
                    padding 0
                    width 100%
                    background-color gray
                    margin 1px 0 0 0
                    display none
                &--active
                    display block
            &__ico
                float right
                background url("media/img/plus.svg") no-repeat center center
                height 15px
                cursor pointer
                padding 10px 50px 0 0
                position absolute
                right 10px
                top 15px
                &--expanded 
                    background:url("media/img/minus.svg") no-repeat center center
            &__ico
                &--bi
                    position absolute
                    top 0
                    left 0
                &--tri
                    position absolute
                    top 0
                    left 0
            &--active
                background-color deepCerulean
                color #FFFFFF
                height auto
                margin-top -3px
                &:after
                    content ""
                    display block
                    height 0
                    width 0
                    border-right 30px solid transparent
                    float right
                    position relative
                    top 4px
                    right -27px
                    border-bottom 40px solid
            &__page
                display none
                &--showcontent
                    display block
        &-page
            &__container
                width 100%
                position relative
                float left
            &__page
                width 100%
                overflow hidden
                .tc
                    .tc-container
                        .tc-menu
                            z-index 999    
    .visible-xs
        display none
// mobile view 
