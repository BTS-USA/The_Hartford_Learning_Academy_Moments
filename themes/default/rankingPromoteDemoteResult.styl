.wizletRankingPromoteDemoteResult

    #contentBox
    {
	    float: none;
    }

    h1
    {
	    font-size: 22px;
	    font-weight: bold;
	    clear: both;
	    text-align: left;
    }

    h2
    {
	    font-size: 16px;
	    font-weight: normal;
	    margin: 0 16px 15px;
	    color: #ffffff;
    }

    ul.RankingPromoteDemoteResult_List
    {
	    list-style: none;
	    padding-left: 0px;
	    margin-left: 0px;
	    width: 100%;
    }

    li.rankingRow_item
    {
	    font-size: 18px;
	    color: #fff;
	    padding: 8px 0px;
	    width: 100%;
	    margin-bottom: 2px;
	    float: left;
	    position: relative;
	    background: url(/Wizer/content/wizletResources/Shared/media/img/bg_white_25.png);	
	    line-height: 26px;
    }

    .RankingPromoteDemoteResult_List li:nth-child(even) { background:none; }

    .RankingPromoteDemote_Content
    {
	    float: left;
	    padding: 0px 310px 0px 10px;
    }

    .RankingPromoteDemote_Result
    {
	    position: absolute;
	    right: 8px;
	    top: 9px;
	    height: 20px;
	    width: 250px;
    }

    .demoted
    {
	    width: 110px;
	    float: left;
    }

    .promoted
    {
	    width: 110px;
	    float: left;
	    margin-left: 1px;
    }

    .sumValue
    {
	    float: right;
    }

    .graph
    {
	    color: #ffffff;
	    height: 26px;
	    margin-top: 0px;
    }

    .demoted .graph
    {
	    float: right;
	    width: 0px;
	    /*background: url(/Wizer/content/WizletResources/RankingPromoteDemoteResult/media/img/demoted_graph.png) repeat-x;*/
	    background: #CC0000; /* old browsers */
	    background: -moz-linear-gradient(top, #CC0000 0%, #790000 100%); /* firefox */
	    background: -webkit-gradient(linear, left top, left bottom, color-stop(40%,#CC0000), color-stop(100%,#790000)); /* webkit */
	    -webkit-border-top-left-radius: 2px;
	    -webkit-border-bottom-left-radius: 2px;
	    -moz-border-radius-topleft: 2px;
	    -moz-border-radius-bottomleft: 2px;
	    border-top-left-radius: 2px;
	    border-bottom-left-radius: 2px;
    }

    .demoted .value
    {
	    color: #ffffff;
	    float: left;
	    display: none;
    }

    .promoted .value
    {
	    color: #ffffff;
	    float: right;
	    display: none;
    }

    .promoted .graph	
    {
	    float: left;
	    width: 0px;
	    /*background: url(/Wizer/content/WizletResources/RankingPromoteDemoteResult/media/img/promoted_graph.png) repeat-x;*/
	    background: #339933; /* old browsers */
	    background: -moz-linear-gradient(top, #339933 0%, #206020 100%); /* firefox */
	    background: -webkit-gradient(linear, left top, left bottom, color-stop(40%,#339933), color-stop(100%,#206020)); /* webkit */
	    -webkit-border-top-right-radius: 2px;
	    -webkit-border-bottom-right-radius: 2px;
	    -moz-border-radius-topright: 2px;
	    -moz-border-radius-bottomright: 2px;
	    border-top-right-radius: 2px;
	    border-bottom-right-radius: 2px;
    }

    .promoted .graphContainer
    {
	    width: 100px;
	    float: left;
    }

    .demoted .graphContainer
    {
	    width: 100px;
	    float: right;
    }

    /* @group continue button area */

    #sendButton
    {
	    width: 128px;
	    height: 42px;
	    background: url(/Wizer/content/wizletResources/Shared/media/img/send_button.png);	
	    border: 0;
	    cursor: pointer;
	    float: right;
    }

    .buttonContainer
    {
	    float: left;
	    margin: 10px 0px;
	    width: 950px;
    }


    #PromoteDemoteResult_Div
    {
	    width: 100%;
	    position: relative;
    }

    .okIcon
    {
	    float: right;
	    padding: 10px;
	    margin-top: -3px;
    }



    .PromoteDemoteResultWizlet
    {
	    position: relative;
	    width: 100%;
	    z-index: 1;
    }

    /* @end */