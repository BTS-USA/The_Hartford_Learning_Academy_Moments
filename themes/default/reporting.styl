    /* ---- MENU STYLE START ---- */

    #menuBar .ddsmoothmenu {
        /* Note: include the "../reporting" part of the URL, because this file is also used by the Tabs wizlet */
	    background: url("../../reporting/media/img/menu_bg.gif") repeat-x; 
	    width: 100%;
	    margin: 0;
	    padding: 0;
	    position:absolute;
	    width:100%;
    }
 
    #menuBar .ddsmoothmenu ul {
	    height: 31px;
	    margin-left: 14px;
	    margin: 0 auto;
    }

    /*Top level menu link items style*/

    #menuBar #rootMenu > li > a {
	    background: transparent;
	    color: #000;
	    line-height: 31px;
	    height: 31px;
    }

    #menuBar .ddsmoothmenu ul li a{
	    background: #000000; /*background of menu items (default state)*/

	    border-right: 1px solid #00182c;
    }
 
    #menuBar .ddsmoothmenu ul li a, #menuBar .ddsmoothmenu ul li a:link, #menuBar .ddsmoothmenu ul li a:visited{
	    color: #cccccc;
	    font-family: Arial, Helvetica, Geneva, sans-serif;
	    font-size: 11px;
    }

    #menuBar .ddsmoothmenu ul li a:hover {
	    background: #9aaec0; /*background of menu items during onmouseover (hover state)*/
	    color: #000000;
    }
 
    /* Sub level menu links style */
    #menuBar .ddsmoothmenu ul li ul li a {
	    /*width: 260px;*/ /*width of sub menus*/
	    padding: 8px 8px;
	    margin: 0;
	    border-top-width: 0;
	    border-bottom: 1px solid #00284b;
    }
 
    .rightarrowclass{
	    position: absolute;
	    top: 8px;
	    right: 10px;
    }

