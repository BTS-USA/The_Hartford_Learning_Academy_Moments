/*  VideoSingleSelect page layout styles */
.teamInfo
    &-input
        .cl-article
            width 50%
            display inline-block
            margin 0 0 20px 0
            float left
            @media (max-width: 768px)
                display block
                width 100%		
        .cl-textarea
            height auto
            width auto
            border 1px solid #a7a9a6