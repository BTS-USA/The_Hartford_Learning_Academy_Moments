@import "../shared/cl.styl"
/* This is css for the layouts in the wizer core*/
/* if you are using a layoutInevent then please let it have its own css called layout.css in the events/layout folder*/
/*
/*  ========================== */
/* Alert page layout styles */
.alert
    height calc(100vh - 150px)
    &-shield
        background black
        width 100%
        height calc(100vh - 45px)
        position absolute
        opacity .3
        z-index -1
    &-inner-container
        text-align center
    &-navigation-holder
        margin 20px 0px 30px 0px
        display inline-block
        position relative
    &-wrapper
        margin 0 auto
        display table
        height 100%
        float none
        @media (max-width: 767px)
        	padding 0
    &-body
        display table-cell
        vertical-align middle
    &__title
        font-size 1.375rem
        line-height 1.000em
    &-text-container
        padding 30px 43px 30px 43px
        min-height 100px
        color #fff
    &__description
        font-size 1.000rem
        line-height 1.000em
        margin-top 30px
    &-page-container
        margin 15px
        @media (max-width: 767px)
            float none
            height 100%
            width 100%
            display block
            background-color #000
            margin 0
            border 1px solid transparent
            border-radius 10px
            height calc(100vh - 85px)
    &-content
        background-color #000
        border 1px solid transparent
        border-radius 10px
    .option-1
        button($apple)
        margin-left 10px
    .option-0
        button($sunsetOrange)