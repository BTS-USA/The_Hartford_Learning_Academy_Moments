@import "../shared/cl.styl"
/* This is css for the layouts in the wizer core*/
/* if you are using a layoutInevent then please let it have its own css called layout.css in the events/layout folder*/

/*  ========================== */
.tbEnterCodePage
    background #FFF
    height calc(100vh - 45px)
    position absolute
    width 100%
    overflow auto
    padding-bottom 100px
    
    .lcpc
        &-inputbox
            border 1px solid $mercury
    
    &__navigation
        .nc-buttons-container
            text-align center
            margin 0
        .nc-button 
            width 27%
            &.option-0
                background $pickledBlueWood