html, body 
    height 100%
    
    .mainContentWrapper
        padding 0px

    *[class*="col-"], .pulseNavigationLink 
        min-height 50px
    .pulseMenuContainer 
        overflow hidden
    .pulseFrontPage, .pulseMenuContainer
        height 80%
        padding-right 0px
        padding-left 0px

        .pulseNavigationPropagation
            display block
            text-align center
            margin 0 auto
        .pulseNavigationView * 
            box-sizing border-box
    
        .pulseNavigationView 
            width 100%
            height 80%
            overflow hidden
            margin 20px auto

        .pulseNavigationSlider
            float left
            position relative
            -webkit-transition  all 0.125s linear 
            -moz-transition  all 0.125s linear 
            -ms-transition  all 0.125s linear 
            -o-transition  all 0.125s linear 
            transition  all 0.125s linear
        .pulseNavigationPanel
            float  left 
            margin-top 20px 
            height 100%
            margin 0 10px
        .pulseNavigationElement
            float left
            -moz-box-sizing border-box
            box-sizing border-box
            display none
         .pulseNavigationElement.active
            display block

        .pulseNavigationElement .pulseNavigationLink
            background-color #333 
            width 100% 
            height 100% 
            display  block 
            color #fff 
            text-align  center 
            vertical-align middle
            background-repeat no-repeat
            background-size 100%
        .pulseNavigationCol 
            height 100% 


        /* custome spacific to event might be generated diring Pagination */
        .pulseNavigationElement .pulseNavigationLink.pulseNav_1
            background-color rgba(0, 174, 239, 0.65) 
            color #fff 

        .pulseNavigationElement .pulseNavigationLink.pulseNav_2
            background-color rgba(255, 79, 58, 0.65) 
            color #fff
        .pulseNavigationElement .pulseNavigationLink.pulseNav_3
            background-color rgba(204, 204, 204, 0.65) 
            color #fff 
        .pulseNavigationElement .pulseNavigationLink.pulseNav_4
            background-color rgba(204, 204, 204, 0.65) 
            color #fff
        .pulseNavigationElement .pulseNavigationLink.pulseNav_5
            background-color rgba(0, 174, 239, 0.65) 
            color #fff 
        .pulseNavigationElement .pulseNavigationLink.pulseNav_6
            background-color rgba(255, 79, 58, 0.65) 
            color #fff 
        .pulseNavigationElement .pulseNavigationLink.pulseNav_7
            background-color rgba(26, 26, 26, 0.65) 
            color #fff
        .pulseNavigationElement .pulseNavigationLink.pulseNav_8
            background-color rgba(255, 210, 55, 0.65) 
            color #fff 
        .pulseNavigationElement .pulseNavigationLink.pulseNav_9
            background-color rgba(133, 95, 168, 0.65)
            color #fff
        .pulseNavigationElement .pulseNavigationLink.pulseNav_10
            background-color rgba(86, 205, 137, 0.65)
            color #fff
        .pulseNavigationElement .pulseNavigationLink.pulseNav_11
            background-color  rgba(0, 174, 239, 0.65) 
            color #fff

        .pulseNavigationControls
            float  left 
            top -20px
            display none

        .pulseNavigationPagination
            display block
            text-align center 
            min-width 300px 
            margin 0 auto
        .pulseNavigationAnchor
            display  inline-block 
            width 10px 
            height 10px 
            background-color  rgba(255, 255, 255, 0.5) 
            border-radius 10px 
            margin 5px

        .pulseNavigationAnchor.active
            background-color #fff

