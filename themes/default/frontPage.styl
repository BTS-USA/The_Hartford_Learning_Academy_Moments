        @media (min-width 768px)
            .pulseNavigationPanel
                width 750px
                height 98%
                clear none
                max-height 670px
                .fix-box-1, .fix-box-2, .fix-box-4, .fix-box-8
                    padding-bottom 10px
                .fix-box-8
                    height 100%
                .fix-box-4
                    height 50%
                .fix-box-2
                    height 25%
                    max-height 25%
                .fix-box-1
                    height 12.5%
                .col-sm-12 
                    width: 100%;
            .pulseNavigationView
                overflow hidden
                max-height 350px
                position fixed
                top calc(50% - 200px)
                left calc(50% - 390px)
            .pulseNavigationControls
                display block
                position fixed
                top calc(50% + 160px)
            .pulseNavigationCol
                height 100%
                padding 0;
            .pulseNavigationSlider
                height 95%
            .pulseNavigationLink
                .linkContent
                    position static
                    h1, h2, h3, h4, h5, h6, h7, p, a, span
                        position static

        @media (min-width  992px)
            .pulseNavigationPanel
                width 970px
            .pulseNavigationPanel
                height 98%
            .pulseNavigationView
                width 990px
                height 90
                max-height 420px
                top calc(50% - 200px)
                left calc(50% - 495px)
            .pulseNavigationControls
                top calc(50% + 240px)
            .fix-box-1, .fix-box-2, .fix-box-4, .fix-box-8
                padding-bottom 10px 
            .fix-box-8
                height 100% 
            .fix-box-4
                height 50% 
            .fix-box-2
                height 25%
                min-height 25%
            .fix-box-1
                height 12.5%

        @media (min-width 1200px)
          .pulseNavigationPanel
            width  1170px 
          .pulseNavigationView
              width 1190px
              top calc(50% - 200px)
              left calc(50% - 600px)