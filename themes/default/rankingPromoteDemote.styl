.wizletRankingPromoteDemote

    body
    {
	    padding: 0;
    }

    #contentBox
    {
	    float: none;
    }

    h1
    {
	    font-size: 22px;
	    font-weight: bold;
    }

    h2
    {
	    font-size: 16px;
	    font-weight: normal;
	    margin: 0px 16px 20px;
    }

    li
    {
	    font-size: 18px;
	    color: #d4eaff;
	    padding: 7px 0px;
	    width: 950px;
	    width: 100%;
	    margin-bottom: 10px;
	    float: left;
	    position: relative;
	    background: url(/Wizer/content/wizletResources/Shared/media/img/blackblue_20_percent.png);
    }

    li.promoted
    {
	    background: url(/Wizer/content/wizletResources/Shared/media/img/green_20_percent.png);
    }

    li.demoted
    {
	    background: url(/Wizer/content/wizletResources/Shared/media/img/red_20_percent.png);
    }

    .RankingPromoteDemote_Content
    {
	    float: left;
	    padding: 0 100px 0 10px;
	    font-size:18px;
    }

    .RankingPromoteDemote_ItemButtons
    {
	    position: absolute;
	    right: 2px;
	    top: 50%;
    }

    .rankingPromoteDemote_Promote
    {
	    width: 40px;
	    height: 40px;
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/grey_1.png) no-repeat;
	    margin-right: 10px;
	    float: right;
	    margin-top: -12px;
	    cursor: pointer;
	    /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=50\);

	    opacity: 0.5;
    }

    .rankingPromoteDemote_Neutral
    {
	    width: 40px;
	    height: 40px;
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/yellow_2.png) no-repeat;
	    margin-right: 10px;
	    float: right;
	    cursor: pointer;
	    margin-top: -12px;

	    /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=80\);

	    opacity: 0.8;
    }

    .rankingPromoteDemote_Demote
    {
	    width: 40px;
	    height: 40px;
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/grey_3.png) no-repeat;
	    margin-right: 10px;
	    float: right;
	    cursor: pointer;
	    margin-top: -12px;
	    /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=50\);

	    opacity: 0.5;
    }

    li.promoted .rankingPromoteDemote_Neutral,
    li.demoted .rankingPromoteDemote_Neutral
    {
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/grey_2.png) no-repeat;
      /* background-size:100%;*/
      /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=50\);

	    opacity: 0.5;
    }

    li.promoted .rankingPromoteDemote_Promote
    {
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/green_1.png) no-repeat;
	    /*background-size:100%;*/
	    /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=100\);

	    opacity: 1;
    }

    li.demoted .rankingPromoteDemote_Demote
    {
	    background: url(/Wizer/content/wizletResources/RankingPromoteDemote/media/img/red_3.png) no-repeat;
	    /*background-size:100%;*/
	    /* For IE  */
	    zoom: 1;
	    filter: alpha\(opacity\=100\);

	    opacity: 1;
    }

    ul
    {
	    list-style: none;
	    padding-right: 4px;
	    margin-left: 0px;
	    padding-left: 0px;
    }

    /* @group continue button area */

    #ranking_TableDiv
    {
	    position: relative;
    }

    .okIcon
    {
	    float: right;
	    padding: 0px 10px;
	    margin-top: -3px;
    }

    .RankingPromoteDemoteWizlet
    {
	    position: relative;
	    z-index: 1;
    }

    .ranking_TableDiv
    {
	    height: auto;
    }

    #sendContainer {
	    float: right;
	    margin-top: 20px;
	    margin-right:1%;
    }

    /* @end */

    /*** Handhelds ***/

    /* iPod */

    @media only screen and (max-device-width: 480px) {
        .RankingPromoteDemote_Content {
            padding-right: 0;
            width: 270px;
        }

        /*#sendContainer {
            bottom: 23px;
        }*/
    }