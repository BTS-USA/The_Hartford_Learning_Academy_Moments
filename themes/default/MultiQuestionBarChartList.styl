.BarChartListAnswer
    .HorizontalBarWraperList            
           
        margin-top: -10px; 
          
.BarChartListAnswer
    .HorizontalBarChartList
        background-color: #434343
        height: 15px
        width: 100%
        float: left
        margin-left: -3px
        margin-bottom: 44px
        border-radius: 25px
        
              
       
.BarChartListAnswer
    .HorizontalBarChartInnerList

        background-color #ee912a        
        height 15px
        border-top-left-radius 25px
        border-bottom-left-radius 25px
        
        


          

.BarChartList
    width 100%
    min-height: 1000px;
    margin 25px auto
    color white
    * 
        box-sizing();
    .BarChartListHeader 
        padding padding
        background-color #00AEEF
        margin-bottom 13px

        h1 
            padding 0
            margin 0 0 10px 0
            font-size 18px
            font-weight normal
            color white
            border none
            text-align center

        .BarChartListText {
            font-size 14px
        }

.BarChartListRow

    display table
    width 100%
    margin-bottom: 10px;
    float:left;
   
    
.BarChartListQuestion 
    overflow hidden
    font-size 13px
    font-family verdana, arial, helvetica, sans-serif
    display table-cell
    padding 13px
    background #DCDEDD
    color grey
    label
        font-weight bold
    .BarChartListDescription
        color lighten(grey,5%);
        font-size 14px
        margin-top 10px
.BarChartListAnswer 
    display table-cell
    vertical-align top
    padding 40px 25px 0px 25px
    background #6B6B6B
    


     

